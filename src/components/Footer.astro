---
import { getTranslations } from '@/i18n';
import { site, footer } from '@/data/site';

const t = getTranslations(Astro.currentLocale || 'es');
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white">
  <div class="container mx-auto px-4 py-16 lg:px-8 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href={site.url}>
          <img
            src="/assets/img/HomiesLogoHoriz.svg"
            alt={site.name}
            class="h-13 w-auto"
          />
        </a>
        <p class="mt-4 text-sm text-gray-400">
          {footer.description}
        </p>
        <div class="mt-6 flex gap-4">
          <a
            href={site.social.facebook}
            class="rounded-full bg-gray-800 p-2 transition-colors hover:bg-primary-600"
            aria-label="Facebook"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href={site.social.instagram}
            class="rounded-full bg-gray-800 p-2 transition-colors hover:bg-primary-600"
            aria-label="Instagram"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href={site.social.tiktok}
            class="rounded-full bg-gray-800 p-2 transition-colors hover:bg-primary-600"
            aria-label="TikTok"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
            </svg>
          </a>
          <a
            href={site.social.threads}
            class="rounded-full bg-gray-800 p-2 transition-colors hover:bg-primary-600"
            aria-label="Threads"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.421,10.983C17.531,11.028 17.631,11.078 17.736,11.123C19.196,11.828 20.266,12.882 20.826,14.192C21.61,16.017 21.685,18.981 19.311,21.351C17.501,23.16 15.297,23.975 12.182,24L12.167,24C8.658,23.975 5.964,22.795 4.149,20.491C2.534,18.441 1.705,15.587 1.675,12.012L1.675,11.988C1.7,8.413 2.529,5.559 4.144,3.509C5.959,1.205 8.658,0.025 12.167,0L12.182,0C15.697,0.025 18.426,1.2 20.296,3.494C21.216,4.629 21.895,5.994 22.325,7.578L20.306,8.118C19.951,6.829 19.416,5.729 18.696,4.849C17.236,3.059 15.047,2.14 12.172,2.12C9.323,2.145 7.169,3.059 5.764,4.839C4.454,6.504 3.774,8.913 3.749,11.998C3.774,15.082 4.454,17.491 5.764,19.161C7.164,20.941 9.323,21.855 12.172,21.88C14.742,21.86 16.442,21.251 17.856,19.836C19.471,18.226 19.441,16.247 18.926,15.042C18.621,14.332 18.071,13.742 17.331,13.297C17.146,14.642 16.742,15.712 16.097,16.537C15.242,17.626 14.027,18.216 12.462,18.301C11.283,18.366 10.148,18.081 9.268,17.501C8.228,16.811 7.618,15.762 7.553,14.537C7.428,12.122 9.338,10.388 12.312,10.218C13.367,10.158 14.357,10.203 15.272,10.358C15.152,9.618 14.907,9.028 14.542,8.598C14.042,8.013 13.262,7.713 12.232,7.708L12.197,7.708C11.368,7.708 10.248,7.938 9.533,9.023L7.813,7.843C8.773,6.389 10.328,5.589 12.202,5.589L12.242,5.589C15.372,5.609 17.236,7.563 17.426,10.973L17.416,10.983L17.421,10.983ZM9.623,14.422C9.688,15.677 11.043,16.262 12.352,16.187C13.632,16.117 15.082,15.617 15.327,12.527C14.667,12.382 13.937,12.307 13.157,12.307C12.917,12.307 12.677,12.312 12.437,12.327C10.293,12.447 9.578,13.487 9.628,14.417L9.623,14.422L9.623,14.422Z"/>
            </svg>
          </a>
          <a
            href={site.social.whatsapp}
            class="rounded-full bg-gray-800 p-2 transition-colors hover:bg-primary-600"
            aria-label="WhatsApp"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.405,3.488C18.161,1.238 15.171,-0 11.995,-0C5.437,-0 0.102,5.336 0.102,11.893C0.102,13.988 0.648,16.034 1.687,17.839L-0,24L6.305,22.345C8.041,23.293 9.996,23.791 11.989,23.791L11.995,23.791C18.546,23.791 24,18.455 24,11.898C24,8.721 22.65,5.738 20.405,3.488L20.405,3.488ZM11.995,21.788C10.216,21.788 8.475,21.311 6.959,20.411L6.6,20.196L2.861,21.177L3.857,17.529L3.621,17.154C2.63,15.579 2.111,13.763 2.111,11.893C2.111,6.445 6.546,2.009 12,2.009C14.641,2.009 17.121,3.038 18.986,4.907C20.85,6.777 21.996,9.257 21.991,11.898C21.991,17.352 17.443,21.788 11.995,21.788ZM17.416,14.384C17.121,14.234 15.659,13.516 15.386,13.42C15.112,13.318 14.914,13.27 14.716,13.57C14.518,13.87 13.95,14.534 13.773,14.737C13.602,14.936 13.425,14.962 13.13,14.812C11.384,13.939 10.237,13.254 9.086,11.277C8.78,10.752 9.391,10.789 9.959,9.654C10.055,9.455 10.007,9.284 9.932,9.134C9.857,8.984 9.262,7.521 9.016,6.927C8.775,6.348 8.529,6.429 8.346,6.418C8.175,6.407 7.977,6.407 7.779,6.407C7.58,6.407 7.259,6.482 6.986,6.777C6.712,7.077 5.946,7.795 5.946,9.257C5.946,10.72 7.012,12.134 7.157,12.332C7.307,12.53 9.252,15.53 12.236,16.821C14.121,17.636 14.861,17.705 15.804,17.566C16.377,17.48 17.561,16.848 17.807,16.152C18.054,15.455 18.054,14.861 17.979,14.738C17.909,14.604 17.711,14.529 17.416,14.384Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="grid gap-8 sm:grid-cols-3 lg:col-span-3">
        {footer.links.map((section) => (
          <div>
            <h3 class="mb-4 font-semibold">{section.title}</h3>
            <ul class="space-y-3">
              {section.items.map((link) => (
                <li>
                  <a
                    href={link.url}
                    class="text-sm text-gray-400 transition-colors hover:text-white"
                  >
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Hours & Contact -->
    <div class="mt-12 grid gap-8 border-t border-gray-800 pt-8 sm:grid-cols-2 lg:grid-cols-3">
      <div>
        <h4 class="mb-2 text-sm font-semibold uppercase tracking-wider text-gray-500">
          {t.footer.hours}
        </h4>
        <p class="text-sm text-gray-400">
          {t.footer.hoursDesc}
        </p>
      </div>
      <div>
        <h4 class="mb-2 text-sm font-semibold uppercase tracking-wider text-gray-500">
          {t.footer.contact}
        </h4>
        <p class="text-sm text-gray-400">{site.email}</p>
        <p class="text-sm text-gray-400">{site.phone}</p>
      </div>
      <div>
        <h4 class="mb-2 text-sm font-semibold uppercase tracking-wider text-gray-500">
          {t.footer.location}
        </h4>
        <p class="text-sm text-gray-400">
          {site.address.street}
        </p>
        <p class="text-sm text-gray-400">
          {site.address.city}, {site.address.state} {site.address.zip}
        </p>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-gray-800 pt-8 sm:flex-row">
      <p class="text-sm text-gray-500">
        {footer.copyright}
      </p>
      <div class="flex gap-6 text-sm text-gray-500">
        <a href="/privacy" class="hover:text-white">{t.footer.privacy}</a>
        <a href="/terms" class="hover:text-white">{t.footer.terms}</a>
      </div>
    </div>
  </div>
</footer>
