---
import { services } from '../data/site'
import { getTranslations } from '@/i18n'

interface Props {
  class?: string
}

const { class: className = '' } = Astro.props
const locale = Astro.currentLocale || 'es'
const t = getTranslations(locale)

const serviceList = services.slice(0, 6)
---

<div id="booking-form-container" class={`booking-form-container ${className}`} data-step="1"
  data-please-select-date={t.booking.pleaseSelectDate}
  data-please-enter-pet-name={t.booking.pleaseEnterPetName}
  data-please-sign-in={t.booking.pleaseSignIn}
  data-booking-error={t.booking.bookingError}
  data-service-label={t.booking.service}
  data-duration-label={t.booking.duration}
  data-total-label={t.booking.total}
  data-pet-label={t.booking.pet}
  data-pet-type-size-label={t.booking.petTypeSize}
  data-total-price-label={t.booking.totalPrice}
>
  <div class="form-progress mb-8">
    <div class="flex items-center justify-between">
      {[1, 2, 3, 4].map((n) => (
        <div class="flex items-center" data-progress-step={n}>
          <div class={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold transition-all duration-300 ${
            n === 1 ? 'bg-accent text-white' : 'bg-dark-200 text-gray-400'
          }`}>
            {n}
          </div>
          {n < 4 && (
            <div class="w-12 sm:w-20 h-0.5 mx-2 bg-dark-200" data-progress-line={n}></div>
          )}
        </div>
      ))}
    </div>
  </div>

  <form id="booking-form" class="space-y-6">
    <input type="hidden" name="service_id" value="" />
    <input type="hidden" name="pet_id" value="" />

    <div class="step-container">
      <div id="step-1" class="step-content" data-step="1">
        <h3 class="text-2xl font-bold text-white mb-2">{t.booking.step1}</h3>
        <p class="text-gray-400 mb-6">{t.booking.step1Desc}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {serviceList.map((service, index) => (
            <button
              type="button"
              class="service-card group p-4 rounded-xl border-2 border-dark-200 bg-dark-300 hover:border-accent transition-all duration-300 text-left relative"
              data-service-index={index}
              data-service-id={index}
            >
              {(service.popular || service.name === 'Dog Walks') && (
                <span class="absolute left-4 top-4 z-10 rounded-full bg-accent-500 px-3 py-1 text-xs font-medium text-white">
                  {t.pricing.discountBadge}
                </span>
              )}
              <div class="aspect-video w-full mb-3 rounded-lg overflow-hidden">
                <img src={service.image} alt={service.name} class="w-full h-full object-cover" loading="lazy" />
              </div>
              <h4 class="text-lg font-semibold text-white group-hover:text-accent transition-colors">{service.name}</h4>
              <p class="text-sm text-gray-400 mt-1 line-clamp-2">{service.description}</p>
              <p class="text-accent font-bold mt-2">{service.price}</p>
            </button>
          ))}
        </div>
        <div class="mt-6 flex justify-end">
          <button type="button" id="next-step-1" class="px-6 py-3 bg-accent text-white rounded-lg font-semibold hover:bg-accent/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>
            {t.booking.nextStep}
          </button>
        </div>
      </div>

      <div id="step-2" class="step-content hidden" data-step="2">
        <h3 class="text-2xl font-bold text-white mb-2">{t.booking.step2}</h3>
        <p class="text-gray-400 mb-6">{t.booking.step2Desc}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-gray-300 mb-2">{t.booking.startDate}</label>
            <input type="date" id="start-date" name="start_date" required class="w-full px-4 py-3 rounded-lg bg-dark-200 border border-dark-200 text-white focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-gray-300 mb-2">{t.booking.endDate}</label>
            <input type="date" id="end-date" name="end_date" class="w-full px-4 py-3 rounded-lg bg-dark-200 border border-dark-200 text-white focus:border-accent focus:outline-none" />
          </div>
        </div>
        <div id="price-summary-2" class="mt-6 p-4 bg-dark-200 rounded-lg hidden">
          <div class="flex justify-between items-center">
            <span class="text-gray-300" data-service-label>{t.booking.service}:</span>
            <span id="selected-service-name" class="text-white font-semibold">-</span>
          </div>
          <div class="flex justify-between items-center mt-2">
            <span class="text-gray-300" data-duration-label>{t.booking.duration}:</span>
            <span id="selected-duration" class="text-white font-semibold">-</span>
          </div>
          <div class="flex justify-between items-center mt-4 pt-4 border-t border-dark-100">
            <span class="text-lg font-bold text-white" data-total-label>{t.booking.total}:</span>
            <span id="selected-total-price" class="text-xl font-bold text-accent">Q.0</span>
          </div>
        </div>
        <div class="mt-6 flex justify-between">
          <button type="button" class="back-btn px-6 py-3 bg-dark-200 text-white rounded-lg font-semibold hover:bg-dark-100 transition-colors" data-goto="1">
            {t.booking.back}
          </button>
          <button type="button" id="next-step-2" class="px-6 py-3 bg-accent text-white rounded-lg font-semibold hover:bg-accent/90 transition-colors">
            {t.booking.nextStep}
          </button>
        </div>
      </div>

      <div id="step-3" class="step-content hidden" data-step="3">
        <h3 class="text-2xl font-bold text-white mb-2">{t.booking.step3}</h3>
        <p class="text-gray-400 mb-6">{t.booking.step3Desc}</p>
        <div id="pet-selection-section">
          <label class="block text-sm text-gray-300 mb-2">{t.booking.pet}</label>
          <select id="pet-select" name="existing_pet" class="w-full px-4 py-3 rounded-lg bg-dark-200 border border-dark-200 text-white focus:border-accent focus:outline-none">
            <option value="">{t.booking.addNewPet}</option>
          </select>
        </div>
        <div id="new-pet-section" class="mt-4 space-y-4 hidden">
          <div>
            <label class="block text-sm text-gray-300 mb-2">{t.booking.petName}</label>
            <input type="text" id="pet-name" name="pet_name" placeholder="e.g. Max" class="w-full px-4 py-3 rounded-lg bg-dark-200 border border-dark-200 text-white placeholder-gray-500 focus:border-accent focus:outline-none" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm text-gray-300 mb-2">{t.booking.petType}</label>
              <select id="pet-type" name="pet_type" class="w-full px-4 py-3 rounded-lg bg-dark-200 border border-dark-200 text-white focus:border-accent focus:outline-none">
                <option value="dog">{t.booking.dog}</option>
                <option value="cat">{t.booking.cat}</option>
                <option value="bird">{t.booking.bird}</option>
                <option value="other">{t.booking.other}</option>
              </select>
            </div>
            <div>
              <label class="block text-sm text-gray-300 mb-2">{t.booking.petSize}</label>
              <select id="pet-size" name="pet_size" class="w-full px-4 py-3 rounded-lg bg-dark-200 border border-dark-200 text-white focus:border-accent focus:outline-none">
                <option value="small">{t.booking.small}</option>
                <option value="medium">{t.booking.medium}</option>
                <option value="large">{t.booking.large}</option>
              </select>
            </div>
          </div>
        </div>
        <div class="mt-4">
          <label class="block text-sm text-gray-300 mb-2">{t.booking.notes}</label>
          <textarea id="pet-notes" name="notes" rows="3" placeholder={t.booking.notesPlaceholder} class="w-full px-4 py-3 rounded-lg bg-dark-200 border border-dark-200 text-white placeholder-gray-500 focus:border-accent focus:outline-none resize-none"></textarea>
        </div>
        <div class="mt-4">
          <label class="block text-sm text-gray-300 mb-2">Number of Pets <span class="text-gray-500">(for combo discount)</span></label>
          <input type="number" id="pet-count" name="pet_count" min="1" value="1" class="w-full px-4 py-3 rounded-lg bg-dark-200 border border-dark-200 text-white focus:border-accent focus:outline-none" />
          <p class="mt-2 text-xs text-gray-400">{t.pricing.pets2Plus}</p>
        </div>
        <div id="discount-info" class="mt-4 p-3 bg-accent-500/10 border border-accent-500/30 rounded-lg hidden">
          <p id="discount-text" class="text-sm text-accent-400"></p>
        </div>
        <div class="mt-6 flex justify-between">
          <button type="button" class="back-btn px-6 py-3 bg-dark-200 text-white rounded-lg font-semibold hover:bg-dark-100 transition-colors" data-goto="2">
            {t.booking.back}
          </button>
          <button type="button" id="next-step-3" class="px-6 py-3 bg-accent text-white rounded-lg font-semibold hover:bg-accent/90 transition-colors">
            {t.booking.nextStep}
          </button>
        </div>
      </div>

      <div id="step-4" class="step-content hidden" data-step="4">
        <h3 class="text-2xl font-bold text-white mb-2">{t.booking.step4}</h3>
        <p class="text-gray-400 mb-6">{t.booking.step4Desc}</p>
        <div class="bg-dark-200 rounded-xl p-6 space-y-4">
          <div class="flex items-start gap-4">
            <img id="confirm-service-image" src="" alt="" class="w-20 h-20 object-cover rounded-lg" />
            <div>
              <h4 id="confirm-service-name" class="text-xl font-bold text-white">-</h4>
              <p id="confirm-service-price" class="text-accent font-semibold">-</p>
            </div>
          </div>
          <div class="border-t border-dark-100 pt-4">
            <div class="flex justify-between">
              <span class="text-gray-400" data-start-date-label>{t.booking.startDate}:</span>
              <span id="confirm-start-date" class="text-white">-</span>
            </div>
            <div class="flex justify-between mt-2">
              <span class="text-gray-400" data-end-date-label>{t.booking.endDate}:</span>
              <span id="confirm-end-date" class="text-white">-</span>
            </div>
            <div class="flex justify-between mt-2">
              <span class="text-gray-400" data-duration-label>{t.booking.duration}:</span>
              <span id="confirm-duration" class="text-white">-</span>
            </div>
          </div>
          <div class="border-t border-dark-100 pt-4">
            <div class="flex justify-between">
              <span class="text-gray-400" data-pet-label>{t.booking.pet}:</span>
              <span id="confirm-pet-name" class="text-white">-</span>
            </div>
            <div class="flex justify-between mt-2">
              <span class="text-gray-400" data-pet-type-size-label>{t.booking.petTypeSize}:</span>
              <span id="confirm-pet-info" class="text-white">-</span>
            </div>
          </div>
          <div class="border-t border-dark-100 pt-4">
            <div class="flex justify-between items-center">
              <span class="text-lg font-bold text-white" data-total-price-label>{t.booking.totalPrice}:</span>
              <span id="confirm-total-price" class="text-2xl font-bold text-accent">Q.0</span>
            </div>
            <div id="confirm-discount-row" class="flex justify-between items-center mt-2 hidden">
              <span class="text-sm text-gray-400">{t.pricing.discountApplied}:</span>
              <span id="confirm-discount" class="text-sm font-semibold text-green-400">-</span>
            </div>
          </div>
        </div>
        <div id="error-message" class="mt-4 p-4 bg-red-500/20 border border-red-500 rounded-lg text-red-400 hidden"></div>
        <div class="mt-6 flex justify-between">
          <button type="button" class="back-btn px-6 py-3 bg-dark-200 text-white rounded-lg font-semibold hover:bg-dark-100 transition-colors" data-goto="3">
            {t.booking.back}
          </button>
          <button type="submit" id="submit-booking" class="px-6 py-3 bg-accent text-white rounded-lg font-semibold hover:bg-accent/90 transition-colors">
            {t.booking.submit}
          </button>
        </div>
      </div>

      <div id="step-5" class="step-content hidden" data-step="5">
        <div class="text-center py-12">
          <div class="w-16 h-16 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-2">{t.booking.success}</h3>
          <p class="text-gray-400 mb-6">{t.booking.successDesc}</p>
          <div class="bg-dark-200 rounded-xl p-6 inline-block">
            <p class="text-sm text-gray-400 mb-1">{t.booking.bookingRef}</p>
            <p id="booking-reference" class="text-xl font-bold text-accent">-</p>
          </div>
          <div class="mt-8">
            <a id="view-bookings-link" href={`/${locale}/dashboard`} class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-white rounded-lg font-semibold hover:bg-accent/90 transition-colors">
              {t.booking.viewBookings}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </form>
</div>

<script>
import { supabase } from '../lib/supabase'
import type { Pet } from '../lib/types'

interface ServiceData {
  name: string
  description: string
  price: string
  duration?: string
  image: string
}

// Read service data from the rendered DOM instead of hardcoding
function getServiceListFromDOM(): ServiceData[] {
  return Array.from(document.querySelectorAll('.service-card')).map((card) => {
    const img = card.querySelector('img')
    const name = card.querySelector('h4')?.textContent?.trim() || ''
    const description = card.querySelector('p.text-sm')?.textContent?.trim() || ''
    const price = card.querySelector('p.text-accent')?.textContent?.trim() || ''
    return {
      name,
      description,
      price,
      image: img?.getAttribute('src') || '',
    }
  })
}

let serviceList: ServiceData[] = []

interface BookingState {
  currentStep: number
  selectedService: { index: number; data: ServiceData } | null
  startDate: string
  endDate: string
  totalPrice: number
  originalPrice: number
  discount: number
  discountReason: string
  petId: string
  newPet: { name: string; type: string; size: string } | null
  notes: string
  petCount: number
}

const state: BookingState = {
  currentStep: 1,
  selectedService: null,
  startDate: '',
  endDate: '',
  totalPrice: 0,
  originalPrice: 0,
  discount: 0,
  discountReason: '',
  petId: '',
  newPet: null,
  notes: '',
  petCount: 1,
}

const formContainer = document.getElementById('booking-form-container') as HTMLElement
const steps = [1, 2, 3, 4, 5]

const tPleaseSelectDate = formContainer.dataset.pleaseSelectDate || 'Por favor selecciona una fecha de inicio'
const tPleaseEnterPetName = formContainer.dataset.pleaseEnterPetName || 'Por favor ingresa el nombre de tu mascota'
const tPleaseSignIn = formContainer.dataset.pleaseSignIn || 'Por favor inicia sesión para hacer una reserva'
const tBookingError = formContainer.dataset.bookingError || 'Error al crear la reserva. Inténtalo de nuevo.'

function updateProgress() {
  steps.forEach((step) => {
    const circle = document.querySelector(`[data-progress-step="${step}"] > div`)
    const line = document.querySelector(`[data-progress-line="${step}"]`)

    if (step < state.currentStep) {
      circle?.classList.remove('bg-dark-200', 'text-gray-400')
      circle?.classList.add('bg-accent', 'text-white')
      if (line) line.classList.add('bg-accent')
    } else if (step === state.currentStep) {
      circle?.classList.remove('bg-dark-200', 'text-gray-400')
      circle?.classList.add('bg-accent', 'text-white')
    }
  })

  document.querySelectorAll('.step-content').forEach((el) => {
    const step = parseInt(el.getAttribute('data-step') || '1')
    if (step === state.currentStep) {
      el.classList.remove('hidden')
    } else {
      el.classList.add('hidden')
    }
  })
}

function showStep(step: number) {
  state.currentStep = step
  updateProgress()
}

function parsePrice(priceStr: string): number {
  const match = priceStr.match(/Q\.\s*(\d+)/)
  return match ? parseInt(match[1]) : 0
}

function calculatePrice() {
  if (!state.selectedService) return 0

  const pricePerUnit = parsePrice(state.selectedService.data.price)
  const start = new Date(state.startDate)
  const end = state.endDate ? new Date(state.endDate) : start

  const diffTime = Math.abs(end.getTime() - start.getTime())
  const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1

  let basePrice = 0
  if (state.selectedService.data.price.includes('/noche') || state.selectedService.data.price.includes('/día')) {
    basePrice = pricePerUnit * diffDays
  } else if (state.selectedService.data.price.includes('/hora')) {
    basePrice = pricePerUnit * diffDays * 8
  } else {
    basePrice = pricePerUnit
  }

  state.originalPrice = basePrice
  state.discount = 0
  state.discountReason = ''

  if (state.selectedService.data.name === 'Dog Walks' && diffDays >= 5) {
    state.discount = 0.10
    state.discountReason = '5+ walks = 10% off'
  }
  if (diffDays >= 7) {
    state.discount = Math.max(state.discount, 0.15)
    state.discountReason = 'Weekly booking = 15% off'
  }
  if (state.petCount >= 2) {
    state.discount = Math.max(state.discount, 0.20)
    state.discountReason = '2+ pets combo = 20% off'
  }

  if (state.discount > 0) {
    state.totalPrice = Math.round(basePrice * (1 - state.discount))
  } else {
    state.totalPrice = basePrice
  }

  return state.totalPrice
}

function showDiscountInfo() {
  const discountInfo = document.getElementById('discount-info')
  const discountText = document.getElementById('discount-text')
  if (discountInfo && discountText) {
    if (state.discount > 0) {
      discountInfo.classList.remove('hidden')
      const savings = state.originalPrice - state.totalPrice
      discountText.textContent = `${state.discountReason} (-Q.${savings})`
    } else {
      discountInfo.classList.add('hidden')
    }
  }
}

function selectService(index: number) {
  state.selectedService = { index, data: serviceList[index] }
  document.querySelectorAll('.service-card').forEach((card, i) => {
    if (i === index) {
      card.classList.add('border-accent')
    } else {
      card.classList.remove('border-accent')
    }
  })
  document.getElementById('next-step-1')?.removeAttribute('disabled')
}

function loadUserPets() {
  supabase.auth.getSession().then(({ data: { session } }) => {
    if (!session) return

    supabase
      .from('pets')
      .select('*')
      .eq('owner_id', session.user.id)
      .then(({ data: pets }) => {
        const petSelect = document.getElementById('pet-select') as HTMLSelectElement
        if (pets && pets.length > 0) {
          pets.forEach((pet: Pet) => {
            const option = document.createElement('option')
            option.value = pet.id
            option.textContent = pet.name || 'Unnamed Pet'
            petSelect.appendChild(option)
          })
        }
      })
  })
}

document.addEventListener('DOMContentLoaded', () => {
  serviceList = getServiceListFromDOM()
  loadUserPets()

  const minDate = new Date().toISOString().split('T')[0]
  const startDateInput = document.getElementById('start-date') as HTMLInputElement
  const endDateInput = document.getElementById('end-date') as HTMLInputElement

  if (startDateInput) startDateInput.min = minDate
  if (endDateInput) endDateInput.min = minDate

  document.querySelectorAll('.service-card').forEach((card, index) => {
    card.addEventListener('click', () => selectService(index))
  })

  document.getElementById('next-step-1')?.addEventListener('click', () => showStep(2))

  document.getElementById('next-step-2')?.addEventListener('click', () => {
    const startDate = (document.getElementById('start-date') as HTMLInputElement).value
    const endDate = (document.getElementById('end-date') as HTMLInputElement).value

    if (!startDate) {
      alert(tPleaseSelectDate)
      return
    }

    state.startDate = startDate
    state.endDate = endDate
    state.totalPrice = calculatePrice()

    const priceSummary = document.getElementById('price-summary-2')
    if (priceSummary) {
      priceSummary.classList.remove('hidden')
      document.getElementById('selected-service-name')!.textContent = state.selectedService?.data.name || '-'
      document.getElementById('selected-duration')!.textContent = endDate
        ? `${Math.ceil((new Date(endDate).getTime() - new Date(startDate).getTime()) / (1000 * 60 * 60 * 24)) + 1} days`
        : '1 day'
      document.getElementById('selected-total-price')!.textContent = `Q.${state.totalPrice}`
      if (state.discount > 0) {
        document.getElementById('selected-total-price')!.classList.add('line-through', 'text-gray-500')
        const discountedSpan = document.createElement('span')
        discountedSpan.id = 'selected-discounted-price'
        discountedSpan.className = 'text-xl font-bold text-accent'
        discountedSpan.textContent = `Q.${state.totalPrice}`
        const parent = document.getElementById('selected-total-price')!.parentElement
        if (parent) {
          parent.appendChild(document.createTextNode(' '))
          parent.appendChild(discountedSpan)
        }
      }
    }

    showStep(3)
  })

  document.getElementById('pet-select')?.addEventListener('change', (e) => {
    const value = (e.target as HTMLSelectElement).value
    const newPetSection = document.getElementById('new-pet-section')
    if (value === '') {
      newPetSection?.classList.remove('hidden')
      state.petId = ''
      state.newPet = { name: '', type: 'dog', size: 'medium' }
    } else {
      newPetSection?.classList.add('hidden')
      state.petId = value
      state.newPet = null
    }
  })

  document.getElementById('next-step-3')?.addEventListener('click', () => {
    const petSelect = document.getElementById('pet-select') as HTMLSelectElement

    if (petSelect.value === '') {
      const petName = (document.getElementById('pet-name') as HTMLInputElement).value
      const petType = (document.getElementById('pet-type') as HTMLSelectElement).value
      const petSize = (document.getElementById('pet-size') as HTMLSelectElement).value

      if (!petName.trim()) {
        alert(tPleaseEnterPetName)
        return
      }

      state.newPet = { name: petName, type: petType, size: petSize }
      state.petId = ''
    }

    state.notes = (document.getElementById('pet-notes') as HTMLTextAreaElement).value
    state.petCount = parseInt((document.getElementById('pet-count') as HTMLInputElement).value) || 1
    state.totalPrice = calculatePrice()
    showDiscountInfo()

    showStep(4)
    updateConfirmationStep()
  })

  function updateConfirmationStep() {
    if (!state.selectedService) return

    document.getElementById('confirm-service-image')!.src = state.selectedService.data.image
    document.getElementById('confirm-service-name')!.textContent = state.selectedService.data.name
    document.getElementById('confirm-service-price')!.textContent = state.selectedService.data.price
    document.getElementById('confirm-start-date')!.textContent = state.startDate || '-'
    document.getElementById('confirm-end-date')!.textContent = state.endDate || '-'

    const days = state.endDate
      ? Math.ceil((new Date(state.endDate).getTime() - new Date(state.startDate).getTime()) / (1000 * 60 * 60 * 24)) + 1
      : 1
    document.getElementById('confirm-duration')!.textContent = `${days} day${days > 1 ? 's' : ''}`

    if (state.petId) {
      supabase
        .from('pets')
        .select('name, species')
        .eq('id', state.petId)
        .single()
        .then(({ data: pet }) => {
          if (pet) {
            document.getElementById('confirm-pet-name')!.textContent = pet.name || '-'
            document.getElementById('confirm-pet-info')!.textContent = pet.species || '-'
          }
        })
    } else if (state.newPet) {
      document.getElementById('confirm-pet-name')!.textContent = state.newPet.name
      document.getElementById('confirm-pet-info')!.textContent = `${state.newPet.type} / ${state.newPet.size}`
    }

    document.getElementById('confirm-total-price')!.textContent = `Q.${state.totalPrice}`

    const discountRow = document.getElementById('confirm-discount-row')
    const discountEl = document.getElementById('confirm-discount')
    if (discountRow && discountEl) {
      if (state.discount > 0) {
        discountRow.classList.remove('hidden')
        const savings = state.originalPrice - state.totalPrice
        discountEl.textContent = `-Q.${savings} (${state.discountReason})`
      } else {
        discountRow.classList.add('hidden')
      }
    }
  }

  document.getElementById('pet-count')?.addEventListener('change', (e) => {
    state.petCount = parseInt((e.target as HTMLInputElement).value) || 1
    state.totalPrice = calculatePrice()
    showDiscountInfo()
  })

  document.querySelectorAll('.back-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const goto = parseInt(btn.getAttribute('data-goto') || '1')
      showStep(goto)
    })
  })

  document.getElementById('submit-booking')?.addEventListener('click', async () => {
    const errorEl = document.getElementById('error-message')
    errorEl?.classList.add('hidden')

    try {
      const { data: { session } } = await supabase.auth.getSession()
      if (!session) {
        alert(tPleaseSignIn)
        const locale = window.location.pathname.split('/')[1] || 'es'
        window.location.href = `/${locale}/login`
        return
      }

      let petId = state.petId

        if (state.newPet && !petId) {
        const { data: newPetData, error: petError } = await supabase
          .from('pets')
          .insert({
            owner_id: session.user.id,
            name: state.newPet.name,
            species: state.newPet.type,
            notes: state.notes,
          })
          .select()
          .single()

        if (petError) throw petError
        petId = newPetData.id
      }

      const serviceName = state.selectedService ? state.selectedService.data.name : null

      const { data: servicesData } = await supabase
        .from('services')
        .select('id')
        .eq('name', serviceName || '')
        .single()

      const { data: caregiversData } = await supabase
        .from('caregivers')
        .select('id')
        .eq('is_available', true)
        .contains('services', [serviceName])
        .limit(1)

      const caregiverId = caregiversData?.[0]?.id

      if (!caregiverId) {
        throw new Error('No caregiver available for this service')
      }

      const { data: bookingData, error: bookingError } = await supabase
        .from('bookings')
        .insert({
          client_id: session.user.id,
          caregiver_id: caregiverId,
          service_id: servicesData?.id || null,
          pet_id: petId,
          start_date: state.startDate,
          end_date: state.endDate || null,
          total_price: state.totalPrice * 100,
          notes: state.notes,
          status: 'pending',
        })
        .select()
        .single()

      if (bookingError) throw bookingError

      const ref = `HOM-${Date.now().toString(36).toUpperCase()}`
      document.getElementById('booking-reference')!.textContent = ref

      showStep(5)
    } catch (error: any) {
      console.error('Booking error:', error)
      if (errorEl) {
        errorEl.textContent = error.message || tBookingError
        errorEl.classList.remove('hidden')
      }
    }
  })
})
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
