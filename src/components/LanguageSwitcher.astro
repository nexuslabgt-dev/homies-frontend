---
import { getRelativeLocaleUrl } from 'astro:i18n'
const currentLocale = Astro.currentLocale || 'es'
---
<div class="flex items-center gap-2">
  <a href={getRelativeLocaleUrl('es')} class:list={['px-2 py-1 text-sm rounded', currentLocale === 'es' ? 'bg-primary-500 text-white' : 'text-gray-400 hover:text-white']}>ES</a>
  <span class="text-gray-600">|</span>
  <a href={getRelativeLocaleUrl('en')} class:list={['px-2 py-1 text-sm rounded', currentLocale === 'en' ? 'bg-primary-500 text-white' : 'text-gray-400 hover:text-white']}>EN</a>
</div>
