---
import type { Caregiver, Profile } from '../lib/types';

interface CaregiverWithProfile extends Caregiver {
  profiles?: Profile | null;
}

interface Props {
  caregiver: CaregiverWithProfile;
}

const { caregiver } = Astro.props;

const fullName = caregiver.profiles?.full_name || 'Unknown';
const avatarUrl = caregiver.profiles?.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(fullName)}&background=1e293b&color=e2e8f0&size=128`;
const rating = caregiver.average_rating || 0;
const specialties = caregiver.specialties || [];
const serviceTypes = caregiver.service_types || [];
const hourlyRate = caregiver.hourly_rate;
const isVerified = caregiver.is_verified;

const availability = typeof caregiver.availability === 'object' && caregiver.availability !== null
  ? (caregiver.availability as { available?: boolean }).available
  : true;
---

<article class="bg-dark-200 rounded-2xl p-6 border border-dark-300 hover:border-primary/50 transition-colors">
  <div class="flex items-start gap-4 mb-4">
    <div class="relative">
      <img
        src={avatarUrl}
        alt={fullName}
        class="w-20 h-20 rounded-full object-cover ring-2 ring-dark-300"
      />
      {availability && (
        <span class="absolute bottom-0 right-0 w-4 h-4 bg-green-500 rounded-full border-2 border-dark-200" title="Disponible"></span>
      )}
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="text-lg font-semibold text-white truncate">{fullName}</h3>
        {isVerified && (
          <svg class="w-5 h-5 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
        )}
      </div>
      <p class="text-gray-400 text-sm">
        {serviceTypes.length > 0 ? serviceTypes.join(' · ') : 'Cuidador'}
      </p>

      {hourlyRate && (
        <p class="text-primary font-semibold mt-1">Q.{hourlyRate}/hora</p>
      )}
    </div>
  </div>

  {rating > 0 && (
    <div class="flex items-center gap-1 mb-4">
      {[1, 2, 3, 4, 5].map((star) => (
        <svg
          class={`w-5 h-5 ${star <= rating ? 'text-yellow-400' : 'text-gray-600'}`}
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      ))}
      <span class="text-gray-400 text-sm ml-1">({rating})</span>
    </div>
  )}

  {specialties.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {specialties.map((specialty) => (
        <span class="px-3 py-1 bg-dark-300 text-gray-300 text-xs rounded-full">
          {specialty}
        </span>
      ))}
    </div>
  )}

  {caregiver.profiles?.bio && (
    <p class="text-gray-400 text-sm mb-4 line-clamp-2">{caregiver.profiles.bio}</p>
  )}

  <a
    href="/messages"
    class="block w-full py-3 bg-primary hover:bg-primary/90 text-white text-center font-medium rounded-xl transition-colors"
  >
    Contactar
  </a>
</article>