---
import { getTranslations } from '@/i18n';
import { supabase } from '@/lib/supabase';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);
---

<div class="w-full max-w-md mx-auto">
  <form id="login-form" class="space-y-6">
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
        {t.login.email}
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
        placeholder={t.login.email}
      />
    </div>

    <div>
      <label for="password" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
        {t.login.password}
      </label>
      <input
        type="password"
        id="password"
        name="password"
        required
        class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
        placeholder="••••••••"
      />
    </div>

    <div id="error-message" class="hidden text-sm text-red-600 dark:text-red-400"></div>

    <button type="submit" class="btn-primary w-full">
      {t.login.submit}
    </button>
  </form>

  <div class="mt-6">
    <div class="relative">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t border-gray-200 dark:border-gray-700"></div>
      </div>
      <div class="relative flex justify-center text-sm">
        <span class="bg-white px-2 text-gray-500 dark:bg-gray-950 dark:text-gray-400">{t.login.or}</span>
      </div>
    </div>

    <button type="button" id="google-signin" class="btn-secondary mt-4 w-full">
      <svg class="mr-2 h-5 w-5" viewBox="0 0 24 24">
        <path
          fill="currentColor"
          d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
        />
        <path
          fill="currentColor"
          d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
        />
        <path
          fill="currentColor"
          d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
        />
        <path
          fill="currentColor"
          d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
        />
      </svg>
      {t.login.google}
    </button>
  </div>
</div>

<script>
  import { supabase } from '@/lib/supabase';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message') as HTMLDivElement;
  const googleBtn = document.getElementById('google-signin') as HTMLButtonElement;

  function getLocale() {
    return window.location.pathname.split('/')[1] || 'es';
  }

  async function checkSession() {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      window.location.href = '/' + getLocale() + '/dashboard';
    }
  }

  checkSession();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    const email = (form.querySelector('#email') as HTMLInputElement).value;
    const password = (form.querySelector('#password') as HTMLInputElement).value;

    const { error } = await supabase.auth.signInWithPassword({
      email,
      password,
    });

    if (error) {
      errorDiv.textContent = error.message;
      errorDiv.classList.remove('hidden');
    } else {
      window.location.href = '/' + getLocale() + '/dashboard';
    }
  });

  googleBtn.addEventListener('click', async () => {
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
    });
    if (error) {
      errorDiv.textContent = error.message;
      errorDiv.classList.remove('hidden');
    }
  });
</script>
