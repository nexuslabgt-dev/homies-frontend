---
import { getTranslations } from '@/i18n';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);
---

<div id="availability-counter" class="flex items-center gap-3 rounded-full bg-green-500/10 px-4 py-2 text-sm" data-locale={locale} data-t-available={t.availabilityCounter.available}>
  <span class="relative flex h-3 w-3">
    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
    <span class="relative inline-flex h-3 w-3 rounded-full bg-green-500"></span>
  </span>
  <span class="font-medium text-green-400">
    <span data-available-text>{t.common.loading}</span>
  </span>
</div>

<script>
  import { supabase } from '../lib/supabase'

  async function loadAvailability() {
    const container = document.getElementById('availability-counter');
    if (!container) return;

    const tAvailable = container.dataset.tAvailable || 'Available caregivers';

    try {
      const { count, error } = await supabase
        .from('caregivers')
        .select('profile_id', { count: 'exact', head: true })
        .eq('is_available', true);

      if (error) throw error;

      const availableText = container.querySelector('[data-available-text]');
      if (availableText) {
        availableText.textContent = `${tAvailable}: ${count ?? 0}`;
      }
    } catch (err) {
      console.error('Failed to load availability:', err);
    }
  }

  document.addEventListener('DOMContentLoaded', loadAvailability);
</script>
