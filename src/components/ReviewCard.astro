---
import type { Review, Profile } from '../lib/types';

interface ReviewWithProfile extends Review {
  profiles?: Profile | null;
}

interface Props {
  review: ReviewWithProfile;
}

const { review } = Astro.props;
const locale = Astro.currentLocale || 'es';

const authorName = review.profiles?.full_name || 'Usuario anónimo';
const authorAvatar = review.profiles?.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(authorName)}&background=1e293b&color=e2e8f0&size=128`;
const rating = review.rating || 0;
const comment = review.comment || '';
const createdAt = new Date(review.created_at);

const formattedDate = createdAt.toLocaleDateString(locale === 'es' ? 'es-ES' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="bg-gray-800 rounded-2xl p-6 border border-gray-700">
  <div class="flex items-start gap-4 mb-4">
    <img
      src={authorAvatar}
      alt={authorName}
      class="w-12 h-12 rounded-full object-cover ring-2 ring-gray-700"
    />
    <div class="flex-1 min-w-0">
      <h4 class="font-semibold text-white truncate">{authorName}</h4>
      <p class="text-gray-500 text-sm">{formattedDate}</p>
    </div>
  </div>

  <div class="flex items-center gap-1 mb-3">
    {[1, 2, 3, 4, 5].map((star) => (
      <svg
        class={`w-5 h-5 ${star <= rating ? 'text-yellow-400' : 'text-gray-600'}`}
        fill="currentColor"
        viewBox="0 0 20 20"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>

  {comment && (
    <p class="text-gray-300 text-sm leading-relaxed">{comment}</p>
  )}
</article>
