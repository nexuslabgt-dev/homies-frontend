---
import { getTranslations } from '@/i18n';
import { securityGuarantee, securityFeatures } from '@/data/site';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);

// Inline SVG icons mapped by name
const icons: Record<string, string> = {
  shield: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  umbrella: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v8"/><path d="M4.93 10A10.05 10.05 0 0 1 12 2a10.05 10.05 0 0 1 7.07 8Z"/><path d="M12 14a2 2 0 0 1-2 2"/><path d="M12 18v4"/></svg>`,
  'alert-circle': `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  lock: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
};
---

<section id="security" class="section-padding bg-primary-50 dark:bg-gray-900">
  <div class="container mx-auto container-padding">
    <div class="mx-auto max-w-6xl">
      <!-- Header -->
      <div class="text-center" data-animate>
        <h2 class="font-display text-3xl font-regular text-gray-900 dark:text-white sm:text-6xl">
          {securityGuarantee.title}
        </h2>
        <p class="mt-4 mx-auto max-w-2xl text-lg text-gray-600 dark:text-gray-400">
          {securityGuarantee.subtitle}
        </p>
      </div>

      <!-- Features Grid -->
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {securityFeatures.map((feature, index) => (
          <div
            class="rounded-2xl bg-white p-6 shadow-soft transition-transform duration-300 hover:-translate-y-1 hover:shadow-soft-md dark:bg-gray-950 dark:shadow-none"
            data-animate
            data-delay={index * 75}
          >
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">
              <Fragment set:html={icons[feature.icon]} />
            </div>
            <h3 class="mt-4 font-semibold text-gray-900 dark:text-white">
              {feature.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
              {feature.description}
            </p>
          </div>
        ))}
      </div>

      <!-- Bottom trust badge -->
      <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-sm text-gray-500 dark:text-gray-400" data-animate>
        <span class="inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Identidad verificada
        </span>
        <span class="hidden sm:inline text-gray-300 dark:text-gray-700">|</span>
        <span class="inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Pagos encriptados
        </span>
        <span class="hidden sm:inline text-gray-300 dark:text-gray-700">|</span>
        <span class="inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Reseñas reales
        </span>
      </div>
    </div>
  </div>
</section>
