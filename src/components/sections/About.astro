---
import { getTranslations } from '@/i18n';
import { about } from '@/data/site';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);
---

<section id="about" class="section-padding bg-primary-50 dark:bg-gray-900">
  <div class="container mx-auto container-padding">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Image -->
      <div class="relative" data-animate>
        <div class="relative aspect-[4/3] overflow-hidden rounded-3xl shadow-xl">
          <img
            src={about.image}
            alt={about.title}
            class="h-full w-full object-cover"
            loading="lazy"
            srcset={`${about.image}?w=400 400w, ${about.image}?w=800 800w, ${about.image}?w=1200 1200w`}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
          />
        </div>
        <!-- Experience badge -->
        <div class="absolute -bottom-4 -right-4 flex h-32 w-32 flex-col items-center justify-center rounded-full bg-primary-600 text-white shadow-xl sm:-bottom-6 sm:-right-6 sm:h-40 sm:w-40">
          <span class="text-3xl font-bold sm:text-4xl">♥+</span>
          <span class="text-sm">{t.about.trust}</span>
        </div>
      </div>

      <!-- Content -->
      <div data-animate data-delay="200">
        <span class="text-sm font-semibold uppercase tracking-wider text-primary-600 dark:text-primary-400">
          {about.subtitle}
        </span>
        <h2 class="mt-2 font-display text-3xl font-regular text-gray-900 dark:text-white sm:text-5xl">
          {about.title}
        </h2>
        <div class="mt-6 space-y-4 text-gray-600 dark:text-gray-400">
          {about.description.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>

        <!-- Features -->
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          {about.features.map((feature, index) => (
            <div
              class="flex gap-4 rounded-xl bg-white p-4 shadow-sm dark:bg-gray-800"
              data-animate
              data-delay={300 + index * 100}
            >
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-100 text-accent-600 dark:bg-accent-900/30 dark:text-accent-400">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-gray-900 dark:text-white">
                  {feature.title}
                </h4>
                <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
                  {feature.description}
                </p>
              </div>
            </div>
          ))}
          <a href="/team" class="btn-secondary mt-4">
            {t.about.learnMore}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
