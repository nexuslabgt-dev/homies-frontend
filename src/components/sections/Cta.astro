---
import { getTranslations } from '@/i18n';
import { site } from '@/data/site';
import Newsletter from '@/components/Newsletter.astro';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);
---

<section class="section-padding bg-linear-to-r from-primary-600 to-primary-700">
  <div class="container mx-auto container-padding text-center">
    <div data-animate>
      <!-- Logo decoration -->
      <div class="mb-8 flex justify-center">
        <img 
          src="/assets/img/HomiesLogo.svg" 
          alt="Homies" 
          class="h-30 w-auto opacity-90"
        />
      </div>

      <h2 class="font-display text-3xl font-regular text-white sm:text-5xl lg:text-7xl">
        {t.cta.heading}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
        {t.cta.subtitle}
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={`/${locale}/contact`}
          class="inline-flex items-center gap-2 rounded-full bg-white px-8 py-4 text-sm font-semibold text-primary-700 shadow-lg transition-all hover:bg-primary-50 hover:shadow-xl"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          {t.cta.bookNow}
        </a>
        <a
          href={`tel:${site.phone.replace(/[^0-9]/g, '')}`}
          class="inline-flex items-center gap-2 rounded-full border-2 border-white/30 px-8 py-4 text-sm font-semibold text-white transition-all hover:border-white hover:bg-white/10"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {site.phone}
        </a>
      </div>
    </div>

    <Newsletter />
  </div>
</section>
