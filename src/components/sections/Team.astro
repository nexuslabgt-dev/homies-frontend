---
import { getTranslations } from '@/i18n';
import { team } from '@/data/site';

const t = getTranslations(Astro.currentLocale || 'es');

interface Props {
  title?: string;
  subtitle?: string;
  showAll?: boolean;
}

const {
  title = t.team.heading,
  subtitle = t.team.subtitle,
  showAll = false
} = Astro.props;

const displayTeam = showAll ? team : team.slice(0, 4);
---

<section class="section-padding bg-gray-50 dark:bg-gray-900">
  <div class="container mx-auto container-padding">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="font-display text-3xl font-regular text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
        {title}
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        {subtitle}
      </p>
    </div>

    <!-- Team Grid -->
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {displayTeam.map((member, index) => (
        <div
          class="group text-center"
          data-animate
          data-delay={index * 100}
        >
          <div class="relative mx-auto mb-6 h-48 w-48 overflow-hidden rounded-full">
            <img
              src={member.image}
              alt={member.name}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>
          <h3 class="font-serif text-xl font-semibold text-gray-900 dark:text-white">
            {member.name}
          </h3>
          <p class="mt-1 text-primary-600 dark:text-primary-400">
            {member.role}
          </p>
          <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
            {member.bio}
          </p>
          {member.rating && (
            <div class="mt-3 flex justify-center gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => {
                const rating = member.rating ?? 0;
                return (
                  <span class={`text-lg ${i < rating ? 'text-accent-500' : 'text-gray-300 dark:text-gray-600'}`}>
                    ★
                  </span>
                );
              })}
            </div>
          )}
          <div class="mt-4 flex flex-wrap justify-center gap-2">
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-primary-100 p-3 text-primary-600 transition hover:bg-primary-200 dark:bg-primary-900/30 dark:text-primary-400 dark:hover:bg-primary-900/50"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </a>
            <a
              href={member.whatsapp}
              class="inline-flex items-center justify-center rounded-full bg-green-100 p-3 text-green-600 transition hover:bg-green-200 dark:bg-green-900/30 dark:text-green-400 dark:hover:bg-green-900/50"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.405,3.488C18.161,1.238 15.171,-0 11.995,-0C5.437,-0 0.102,5.336 0.102,11.893C0.102,13.988 0.648,16.034 1.687,17.839L-0,24L6.305,22.345C8.041,23.293 9.996,23.791 11.989,23.791L11.995,23.791C18.546,23.791 24,18.455 24,11.898C24,8.721 22.65,5.738 20.405,3.488L20.405,3.488ZM11.995,21.788C10.216,21.788 8.475,21.311 6.959,20.411L6.6,20.196L2.861,21.177L3.857,17.529L3.621,17.154C2.63,15.579 2.111,13.763 2.111,11.893C2.111,6.445 6.546,2.009 12,2.009C14.641,2.009 17.121,3.038 18.986,4.907C20.85,6.777 21.996,9.257 21.991,11.898C21.991,17.352 17.443,21.788 11.995,21.788ZM17.416,14.384C17.121,14.234 15.659,13.516 15.386,13.42C15.112,13.318 14.914,13.27 14.716,13.57C14.518,13.87 13.95,14.534 13.773,14.737C13.602,14.936 13.425,14.962 13.13,14.812C11.384,13.939 10.237,13.254 9.086,11.277C8.78,10.752 9.391,10.789 9.959,9.654C10.055,9.455 10.007,9.284 9.932,9.134C9.857,8.984 9.262,7.521 9.016,6.927C8.775,6.348 8.529,6.429 8.346,6.418C8.175,6.407 7.977,6.407 7.779,6.407C7.58,6.407 7.259,6.482 6.986,6.777C6.712,7.077 5.946,7.795 5.946,9.257C5.946,10.72 7.012,12.134 7.157,12.332C7.307,12.53 9.252,15.53 12.236,16.821C14.121,17.636 14.861,17.705 15.804,17.566C16.377,17.48 17.561,16.848 17.807,16.152C18.054,15.455 18.054,14.861 17.979,14.738C17.909,14.604 17.711,14.529 17.416,14.384Z"/>
              </svg>
            </a>
            <a
              href={`mailto:${member.email}`}
              class="inline-flex items-center justify-center rounded-full bg-gray-100 p-3 text-gray-600 transition hover:bg-gray-200 dark:bg-gray-700/50 dark:text-gray-400 dark:hover:bg-gray-700"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    {!showAll && (
      <div class="mt-12 text-center" data-animate>
        <a href="/team" class="btn-primary inline-flex items-center gap-2">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          {t.team.search}
        </a>
      </div>
    )}
  </div>
</section>
