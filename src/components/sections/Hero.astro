---
import { getTranslations } from '@/i18n';
import { hero } from '@/data/site';
import AvailabilityCounter from '../AvailabilityCounter.astro';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);
---

<section class="relative overflow-hidden bg-linear-to-br from-primary-50 via-white to-accent-50 pt-24 dark:from-gray-900 dark:via-gray-950 dark:to-gray-900 lg:pt-32">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Content -->
      <div class="max-w-xl" data-animate>
        <div class="mb-4">
          <AvailabilityCounter />
        </div>
        <h1 class="font-display text-4xl font-regular leading-tight text-gray-900 dark:text-white sm:text-6xl lg:text-6xl">
          {t.hero.title}
        </h1>
        <p class="mt-6 text-lg text-gray-600 dark:text-gray-400">
          {hero.subtitle}
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href={hero.primaryCta.url} class="btn-primary">
            {t.hero.cta}
          </a>
          <a href={hero.secondaryCta.url} class="btn-secondary">
            {t.hero.ctaSecondary}
          </a>
        </div>
        <!-- Stats -->
        <div class="mt-12 grid grid-cols-2 gap-4 sm:grid-cols-4">
          {hero.stats.map(stat => (
            <div class="text-center">
              <div class="text-2xl font-bold text-primary-500 sm:text-3xl">{stat.value}</div>
              <div class="text-sm text-gray-600 dark:text-gray-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Image -->
      <div class="relative" data-animate data-delay="200">
        <div class="relative aspect-[4/3] overflow-hidden rounded-3xl shadow-2xl">
          <img
            src={hero.image}
            alt={t.hero.imageAlt}
            class="h-full w-full object-cover"
            loading="eager"
            srcset={`${hero.image}?w=400 400w, ${hero.image}?w=800 800w, ${hero.image}?w=1200 1200w`}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
          />
        </div>
        <!-- Decorative elements -->
        <div class="absolute -bottom-6 -left-6 h-24 w-24 rounded-2xl bg-accent-400 opacity-50 blur-2xl"></div>
        <div class="absolute -right-6 -top-6 h-32 w-32 rounded-full bg-primary-400 opacity-50 blur-2xl"></div>
      </div>
    </div>
  </div>

  <!-- Wave decoration -->
  <div class="mt-16 lg:mt-24">
    <svg class="w-full" viewBox="0 0 1440 100" fill="none" preserveAspectRatio="none">
      <path
        d="M0 50C240 100 480 0 720 50C960 100 1200 0 1440 50V100H0V50Z"
        class="fill-white dark:fill-gray-950"
      />
    </svg>
  </div>
</section>
