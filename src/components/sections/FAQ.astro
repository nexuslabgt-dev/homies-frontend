---
import { getTranslations } from '@/i18n';
import { faqs } from '@/data/site';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = t.faq.heading,
  subtitle = t.faq.subtitle
} = Astro.props;
---

<section id="faq" class="section-padding bg-white dark:bg-gray-950">
  <div class="container mx-auto container-padding">
    <div class="mx-auto max-w-3xl">
      <!-- Header -->
      <div class="text-center" data-animate>
        <h2 class="font-display text-3xl font-regular text-gray-900 dark:text-white sm:text-6xl">
          {title}
        </h2>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
          {subtitle}
        </p>
      </div>

      <!-- FAQ Accordion -->
      <div class="mt-12 space-y-4">
        {faqs.map((faq, index) => (
          <details
            class="group rounded-2xl bg-gray-50 p-6 open:bg-white open:shadow-soft dark:bg-gray-900 dark:open:bg-gray-900 dark:open:shadow-none transition-all duration-300"
            data-animate
            data-delay={index * 50}
          >
            <summary class="flex cursor-pointer items-center justify-between gap-4 list-none">
              <h3 class="font-semibold text-gray-900 dark:text-white text-left">
                {faq.question}
              </h3>
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary-100 text-primary-600 transition-transform duration-300 group-open:rotate-180 dark:bg-primary-900/30 dark:text-primary-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </span>
            </summary>
            <div class="overflow-hidden transition-all duration-300">
              <p class="mt-4 text-gray-600 dark:text-gray-400 leading-relaxed">
                {faq.answer}
              </p>
            </div>
          </details>
        ))}
      </div>

      <!-- Contact CTA -->
      <div class="mt-12 rounded-2xl bg-primary-50 p-8 text-center dark:bg-gray-900" data-animate>
        <h3 class="font-semibold text-gray-900 dark:text-white">
          {t.faq.contact}
        </h3>
        <p class="mt-2 text-gray-600 dark:text-gray-400">
          {t.faq.contactDesc}
        </p>
        <a href={`/${locale}/contact`} class="btn-primary mt-4 inline-block">
          {t.faq.contactCta}
        </a>
      </div>
    </div>
  </div>
</section>
