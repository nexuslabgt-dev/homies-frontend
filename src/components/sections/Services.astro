---
import { getTranslations } from '@/i18n';
import { services } from '@/data/site';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);

interface Props {
  title?: string;
  subtitle?: string;
  showAll?: boolean;
}

const {
  title = t.services.heading,
  subtitle = t.services.subtitle,
  showAll = false
} = Astro.props;

const displayServices = showAll ? services : services.slice(0, 6);
---

<section id="services" class="section-padding bg-white dark:bg-gray-950">
  <div class="container mx-auto container-padding">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="font-display text-3xl font-regular text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
        {title}
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        {subtitle}
      </p>
    </div>

    <!-- Services Grid -->
    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {displayServices.map((service, index) => (
        <div
          class="group relative overflow-hidden rounded-2xl bg-gray-50 transition-all hover:shadow-xl dark:bg-gray-900"
          data-animate
          data-delay={index * 100}
        >
          {service.popular && (
            <span class="absolute right-4 top-4 z-10 rounded-full bg-accent-500 px-3 py-1 text-xs font-medium text-white">
              {t.services.popular}
            </span>
          )}
          {service.soon && (
            <span class="absolute right-4 top-4 z-10 rounded-full bg-secondary-600 px-3 py-1 text-xs font-medium text-white">
              {t.services.soon}
            </span>
          )}
          <div class="aspect-video overflow-hidden">
            <img
              src={service.image}
              alt={service.name}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              srcset={`${service.image}?w=400 400w, ${service.image}?w=800 800w, ${service.image}?w=1200 1200w`}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            />
          </div>
          <div class="p-6">
            <div class="flex items-start justify-between gap-4">
              <h3 class="font-serif text-xl font-semibold text-gray-900 dark:text-white">
                {service.name}
              </h3>
              <span class="shrink-0 rounded-full bg-primary-100 px-3 py-1 text-sm font-semibold text-primary-700 dark:bg-primary-900/30 dark:text-primary-400">
                {service.price}
              </span>
            </div>
            <p class="mt-2 text-gray-600 dark:text-gray-400">
              {service.description}
            </p>
            {service.duration && (
              <p class="mt-4 text-sm text-gray-500 dark:text-gray-500">
                {service.duration}
              </p>
            )}
            {service.features && (
              <ul class="mt-4 space-y-2">
                {service.features.slice(0, 3).map((feature) => (
                  <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                    <svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>

    {!showAll && (
      <div class="mt-12 text-center" data-animate>
        <a href="/services" class="btn-secondary">
          {t.services.seeAll}
        </a>
      </div>
    )}
  </div>
</section>
