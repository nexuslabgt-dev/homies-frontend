---
import { getTranslations } from '@/i18n';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);

const mapUrl = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15442.273487!2d-90.735!3d14.558!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8589a3c6f3c0f1c1%3A0x7c6d6f6f6f6f6f6!2sAntigua%20Guatemala!5e0!3m2!1sen!2sgt!4v1700000000000!5m2!1sen!2sgt";
---

<section id="coverage" class="section-padding bg-white dark:bg-gray-950">
  <div class="container mx-auto container-padding">
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="font-display text-3xl font-regular text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
        {t.coverage.title}
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        {t.coverage.subtitle}
      </p>
    </div>

    <div class="mt-12" data-animate>
      <div class="aspect-video overflow-hidden rounded-2xl shadow-xl">
        <iframe
          src={mapUrl}
          class="w-full h-full"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
        />
      </div>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-3" data-animate>
      <div class="text-center rounded-2xl bg-gray-50 p-8 dark:bg-gray-900">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-accent-100 dark:bg-accent-900/30">
          <svg class="h-8 w-8 text-accent-600 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 class="font-serif text-xl font-semibold text-gray-900 dark:text-white">
          {t.coverage.center}
        </h3>
        <p class="mt-2 text-gray-600 dark:text-gray-400">
          {t.coverage.centerDesc}
        </p>
      </div>

      <div class="text-center rounded-2xl bg-gray-50 p-8 dark:bg-gray-900">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-accent-100 dark:bg-accent-900/30">
          <svg class="h-8 w-8 text-accent-600 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
        </div>
        <h3 class="font-serif text-xl font-semibold text-gray-900 dark:text-white">
          {t.coverage.jocotenango}
        </h3>
        <p class="mt-2 text-gray-600 dark:text-gray-400">
          {t.coverage.jocotenangoDesc}
        </p>
      </div>

      <div class="text-center rounded-2xl bg-gray-50 p-8 dark:bg-gray-900">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-accent-100 dark:bg-accent-900/30">
          <svg class="h-8 w-8 text-accent-600 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="font-serif text-xl font-semibold text-gray-900 dark:text-white">
          {t.coverage.ciudadVieja}
        </h3>
        <p class="mt-2 text-gray-600 dark:text-gray-400">
          {t.coverage.ciudadViejaDesc}
        </p>
      </div>
    </div>

    <div class="mt-12 text-center" data-animate>
      <a
        href="https://www.google.com/maps/search/Antigua+Guatemala"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
        {t.coverage.getDirections}
      </a>
    </div>
  </div>
</section>