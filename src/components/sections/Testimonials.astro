---
import { getTranslations } from '@/i18n';
import { testimonials } from '@/data/site';

const t = getTranslations(Astro.currentLocale || 'es');
---

<section class="section-padding bg-primary-600 dark:bg-primary-900">
  <div class="container mx-auto container-padding">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="font-display text-3xl font-regular text-white sm:text-5xl lg:text-6xl">
        {t.testimonials.heading}
      </h2>
      <p class="mt-4 text-lg text-primary-100">
        {t.testimonials.subtitle}
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {testimonials.map((testimonial, index) => (
        <div
          class="rounded-2xl bg-white p-6 shadow-lg dark:bg-gray-800"
          data-animate
          data-delay={index * 100}
        >
          <!-- Stars -->
          <div class="flex gap-1">
            {Array.from({ length: testimonial.rating }).map(() => (
              <svg class="h-5 w-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="mt-4 text-gray-600 dark:text-gray-300">
            "{testimonial.quote}"
          </p>

          <!-- Author -->
          <div class="mt-6 flex items-center gap-3">
            <img
              src={testimonial.image}
              alt={testimonial.author}
              class="h-12 w-12 rounded-full object-cover"
              loading="lazy"
            />
            <div>
              <p class="font-semibold text-gray-900 dark:text-white">
                {testimonial.author}
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-400">
                {testimonial.pet}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
