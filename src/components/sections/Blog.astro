---
import { getTranslations } from '@/i18n';
import BlogCard from '@/components/BlogCard.astro';
import { blogPosts } from '@/data/blog';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);
---

<section class="section-padding bg-white dark:bg-gray-950">
  <div class="container mx-auto container-padding">
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="font-display text-3xl font-regular text-gray-900 dark:text-white sm:text-5xl">
        {t.blog?.heading || 'Blog de Tips'}
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        {t.blog?.subtitle || 'Consejos y guías para el cuidado de tus mascotas'}
      </p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {blogPosts.map((post, index) => (
        <div data-animate data-delay={index * 100}>
          <BlogCard post={post} locale={locale} />
        </div>
      ))}
    </div>

    <div class="mt-12 text-center" data-animate>
      <a href={`/${locale}/blog`} class="btn-secondary">
        {t.blog?.seeAll || 'Ver todas las publicaciones'}
      </a>
    </div>
  </div>
</section>