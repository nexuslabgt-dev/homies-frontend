---
import { getTranslations } from '@/i18n';

interface Props {
  bookingId: string;
  caregiverId: string;
  userId: string;
}

const { bookingId, caregiverId, userId } = Astro.props;
const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);
---

<form id="review-form" data-booking-id={bookingId} data-caregiver-id={caregiverId} data-user-id={userId}
  data-select-rating={t.reviews.rating}
  data-submitting={t.reviews.submitting}
  data-error-default={t.reviews.error}
  data-thank-you={t.reviews.thankYou}
  data-thank-you-desc={t.reviews.thankYouDesc}
  class="bg-gray-800 rounded-2xl p-6 border border-gray-700">
  <h3 class="text-lg font-semibold text-white mb-4">{t.reviews.leaveReview}</h3>

  <div id="review-error" class="hidden bg-red-900/30 border border-red-700 rounded-lg p-3 mb-4 text-red-400 text-sm"></div>
  
  <div id="review-success" class="hidden bg-green-900/30 border border-green-700 rounded-2xl p-6 text-center">
    <svg class="w-12 h-12 text-green-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <h3 class="text-xl font-semibold text-white mb-2">{t.reviews.thankYou}</h3>
    <p class="text-gray-400">{t.reviews.thankYouDesc}</p>
  </div>

  <div id="review-fields">
    <div class="mb-4">
      <label class="block text-gray-300 text-sm font-medium mb-2">{t.reviews.rating}</label>
      <div class="flex gap-2" id="star-rating">
        {[1, 2, 3, 4, 5].map((star) => (
          <button
            type="button"
            data-rating={star}
            class="star-btn text-gray-600 hover:text-yellow-400 transition-colors"
          >
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </button>
        ))}
      </div>
    </div>

    <div class="mb-4">
      <label for="comment" class="block text-gray-300 text-sm font-medium mb-2">{t.reviews.comment}</label>
      <textarea
        id="comment"
        rows="4"
        class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none"
        placeholder={t.reviews.commentPlaceholder}
        required
      ></textarea>
    </div>

    <button
      type="submit"
      id="submit-review"
      class="w-full py-3 bg-primary hover:bg-primary/90 disabled:bg-gray-600 disabled:cursor-not-allowed text-white font-medium rounded-xl transition-colors"
    >
      {t.reviews.submit}
    </button>
  </div>
</form>

<script>
  import { supabase } from '../lib/supabase';
  
  const form = document.getElementById('review-form') as HTMLFormElement;
  const bookingId = form.dataset.bookingId!;
  const caregiverId = form.dataset.caregiverId!;
  const userId = form.dataset.userId!;
  
  const tSelectRating = form.dataset.selectRating || 'Por favor selecciona una calificación.';
  const tSubmitting = form.dataset.submitting || 'Enviando...';
  const tErrorDefault = form.dataset.errorDefault || 'Error al enviar la reseña.';
  const tThankYou = form.dataset.thankYou || 'Gracias por tu reseña!';
  const tThankYouDesc = form.dataset.thankYouDesc || 'Tu opinión ayuda a otros usuarios a elegir al mejor cuidador.';
  
  let currentRating = 0;

  document.querySelectorAll('.star-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const star = parseInt((btn as HTMLElement).dataset.rating!);
      currentRating = star;
      document.querySelectorAll('.star-btn').forEach((b, index) => {
        if (index < star) {
          b.classList.remove('text-gray-600');
          b.classList.add('text-yellow-400');
        } else {
          b.classList.remove('text-yellow-400');
          b.classList.add('text-gray-600');
        }
      });
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById('submit-review') as HTMLButtonElement;
    const errorEl = document.getElementById('review-error') as HTMLDivElement;
    const successEl = document.getElementById('review-success') as HTMLDivElement;
    const fieldsEl = document.getElementById('review-fields') as HTMLDivElement;

    if (currentRating === 0) {
      errorEl.textContent = tSelectRating;
      errorEl.classList.remove('hidden');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = tSubmitting;
    errorEl.classList.add('hidden');

    try {
      const { error } = await supabase.from('reviews').insert({
        booking_id: bookingId,
        caregiver_id: caregiverId,
        author_id: userId,
        rating: currentRating,
        comment: (document.getElementById('comment') as HTMLTextAreaElement).value,
      });

      if (error) throw error;

      fieldsEl.classList.add('hidden');
      successEl.classList.remove('hidden');
    } catch (err: any) {
      errorEl.textContent = err.message || tErrorDefault;
      errorEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar Resena';
    }
  });
</script>
