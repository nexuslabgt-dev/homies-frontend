---
import { supabase } from '../lib/supabase';

interface Props {
  bookingId: string;
  caregiverId: string;
  userId: string;
}

const { bookingId, caregiverId, userId } = Astro.props;

let rating = 0;
let comment = '';
let isSubmitting = false;
let isSuccess = false;
let error = '';

async function handleSubmit(e: Event) {
  e.preventDefault();
  isSubmitting = true;
  error = '';

  const { error: insertError } = await supabase
    .from('reviews')
    .insert({
      booking_id: bookingId,
      caregiver_id: caregiverId,
      author_id: userId,
      rating,
      comment
    });

  if (insertError) {
    error = 'Error al enviar la reseña. Intenta de nuevo.';
    isSubmitting = false;
  } else {
    isSuccess = true;
  }
}
---

{isSuccess ? (
  <div class="bg-green-900/30 border border-green-700 rounded-2xl p-6 text-center">
    <svg class="w-12 h-12 text-green-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <h3 class="text-xl font-semibold text-white mb-2">¡Gracias por tu reseña!</h3>
    <p class="text-gray-400">Tu opinión ayuda a otros usuarios a elegir al mejor cuidador.</p>
  </div>
) : (
  <form onsubmit="handleSubmit(event)" class="bg-gray-800 rounded-2xl p-6 border border-gray-700">
    <h3 class="text-lg font-semibold text-white mb-4">Deja tu reseña</h3>

    {error && (
      <div class="bg-red-900/30 border border-red-700 rounded-lg p-3 mb-4 text-red-400 text-sm">
        {error}
      </div>
    )}

    <div class="mb-4">
      <label class="block text-gray-300 text-sm font-medium mb-2">Calificación</label>
      <div class="flex gap-2" id="star-rating">
        {[1, 2, 3, 4, 5].map((star) => (
          <button
            type="button"
            data-rating={star}
            class="star-btn text-gray-600 hover:text-yellow-400 transition-colors"
            onclick={`setRating(${star})`}
          >
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </button>
        ))}
      </div>
    </div>

    <div class="mb-4">
      <label for="comment" class="block text-gray-300 text-sm font-medium mb-2">Comentario</label>
      <textarea
        id="comment"
        bind:value={comment}
        rows="4"
        class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none"
        placeholder="Cuéntanos tu experiencia con este cuidador..."
        required
      ></textarea>
    </div>

    <button
      type="submit"
      disabled={isSubmitting || rating === 0}
      class="w-full py-3 bg-primary hover:bg-primary/90 disabled:bg-gray-600 disabled:cursor-not-allowed text-white font-medium rounded-xl transition-colors"
    >
      {isSubmitting ? 'Enviando...' : 'Enviar Reseña'}
    </button>
  </form>
)}

<script is:inline define:vars={{ rating }}>
  window.currentRating = rating;
  
  window.setRating = function(star) {
    window.currentRating = star;
    document.querySelectorAll('.star-btn').forEach((btn, index) => {
      const svg = btn.querySelector('svg');
      if (index < star) {
        btn.classList.remove('text-gray-600');
        btn.classList.add('text-yellow-400');
      } else {
        btn.classList.remove('text-yellow-400');
        btn.classList.add('text-gray-600');
      }
    });
  };
</script>
