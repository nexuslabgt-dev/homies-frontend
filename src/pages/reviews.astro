---
import { supabase } from '../lib/supabase';
import ReviewCard from '../components/ReviewCard.astro';
import CaregiverReviews from '../components/CaregiverReviews.astro';

const { data: reviews, error } = await supabase
  .from('reviews')
  .select('*, profiles(full_name, avatar_url), caregivers(profile_id, profiles(full_name))')
  .order('created_at', { ascending: false });

const averageRating = reviews && reviews.length > 0
  ? reviews.reduce((sum, r) => sum + (r.rating || 0), 0) / reviews.length
  : 0;

const ratingFilter = Astro.url.searchParams.get('rating') || 'all';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reseñas - Homies Pets</title>
  </head>
  <body class="bg-dark-100 text-white min-h-screen">
    <header class="bg-dark-200 border-b border-dark-300">
      <nav class="container mx-auto px-4 py-4">
        <a href="/" class="text-2xl font-bold text-primary">Homies Pets</a>
      </nav>
    </header>

    <main>
      <section class="bg-gradient-to-b from-dark-200 to-dark-100 py-16">
        <div class="container mx-auto px-4 text-center">
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Lo que dicen nuestros clientes</h1>
          <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-8">
            Descubre las experiencias de otros dueños de mascotas con nuestros cuidadores.
          </p>

          {reviews && reviews.length > 0 && (
            <div class="flex items-center justify-center gap-4">
              <span class="text-6xl font-bold text-white">{averageRating.toFixed(1)}</span>
              <div class="text-left">
                <div class="flex items-center gap-1 mb-1">
                  {[1, 2, 3, 4, 5].map((star) => (
                    <svg
                      class={`w-8 h-8 ${star <= Math.round(averageRating) ? 'text-yellow-400' : 'text-gray-600'}`}
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                </div>
                <p class="text-gray-400">{reviews.length} reseñas</p>
              </div>
            </div>
          )}
        </div>
      </section>

      <section class="container mx-auto px-4 py-12">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
          <h2 class="text-2xl font-semibold text-white">Todas las reseñas</h2>

          <div class="flex gap-2">
            {['all', '5', '4', '3', '2', '1'].map((filter) => (
              <a
                href={filter === 'all' ? '/reviews' : `/reviews?rating=${filter}`}
                class:list={[
                  'px-4 py-2 rounded-lg text-sm font-medium transition-colors',
                  ratingFilter === filter
                    ? 'bg-primary text-white'
                    : 'bg-gray-800 text-gray-400 hover:bg-gray-700'
                ]}
              >
                {filter === 'all' ? 'Todas' : `${filter} estrellas`}
              </a>
            ))}
          </div>
        </div>

        {reviews && reviews.length > 0 ? (
          <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            {reviews
              .filter((r) => ratingFilter === 'all' || r.rating?.toString() === ratingFilter)
              .map((review) => (
                <ReviewCard review={review} />
              ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <svg class="w-20 h-20 text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            <p class="text-gray-400 text-lg">No hay reseñas todavía</p>
            <p class="text-gray-500 text-sm mt-1">Sé el primero en compartir tu experiencia.</p>
          </div>
        )}
      </section>
    </main>

    <footer class="bg-dark-200 border-t border-dark-300 py-8 mt-16">
      <div class="container mx-auto px-4 text-center text-gray-500 text-sm">
        <p>&copy; 2024 Homies Pets. Todos los derechos reservados.</p>
      </div>
    </footer>
  </body>
</html>
