---
import Base from '@/layouts/Base.astro';
import { serviceCategories, services } from '@/data/site';
---

<Base title="Services" headerVariant="dark">
  <!-- Hero Section -->
  <section class="relative bg-primary-600 pb-20 pt-32 lg:pb-28 lg:pt-40">
    <div class="container mx-auto px-4 text-center lg:px-8">
      <h1 class="font-serif text-4xl font-bold text-white sm:text-5xl">
        Our Services
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
        Complete pet care services from grooming to boarding. Everything your furry friend needs under one roof.
      </p>
    </div>
  </section>

  <!-- Services by Category -->
  {serviceCategories.map((category, catIndex) => (
    <section
      id={category.name.toLowerCase().replace(/\s+/g, '-')}
      class:list={[
        "section-padding",
        catIndex % 2 === 0 ? "bg-white dark:bg-gray-950" : "bg-gray-50 dark:bg-gray-900"
      ]}
    >
      <div class="container mx-auto container-padding">
        <div class="mb-12" data-animate>
          <h2 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">
            {category.name}
          </h2>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            {category.description}
          </p>
        </div>

        <div class="grid gap-8 lg:grid-cols-2">
          {category.services.map((service, index) => (
            <div
              class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-lg dark:bg-gray-800 sm:flex-row"
              data-animate
              data-delay={index * 100}
            >
              <div class="aspect-video overflow-hidden sm:aspect-square sm:w-1/3">
                <img
                  src={service.image}
                  alt={service.name}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="font-serif text-xl font-semibold text-gray-900 dark:text-white">
                      {service.name}
                    </h3>
                    {service.popular && (
                      <span class="mt-1 inline-block rounded-full bg-accent-100 px-2 py-0.5 text-xs font-medium text-accent-700 dark:bg-accent-900/30 dark:text-accent-400">
                        Popular
                      </span>
                    )}
                  </div>
                  <div class="text-right">
                    <span class="text-lg font-bold text-primary-600 dark:text-primary-400">
                      {service.price}
                    </span>
                    {service.duration && (
                      <p class="text-sm text-gray-500">{service.duration}</p>
                    )}
                  </div>
                </div>
                <p class="mt-3 text-gray-600 dark:text-gray-400">
                  {service.description}
                </p>
                {service.features && (
                  <ul class="mt-4 flex-1 space-y-2">
                    {service.features.map((feature) => (
                      <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                        <svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        {feature}
                      </li>
                    ))}
                  </ul>
                )}
                <a
                  href="/contact"
                  class="mt-6 inline-flex items-center gap-2 font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400"
                >
                  Book Now
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Pricing Note -->
  <section class="bg-primary-50 py-12 dark:bg-gray-900">
    <div class="container mx-auto px-4 text-center lg:px-8">
      <p class="text-gray-600 dark:text-gray-400">
        <strong class="text-gray-900 dark:text-white">Note:</strong> Prices may vary based on pet size, coat condition, and specific requirements.
        Contact us for a personalized quote.
      </p>
      <a href="/contact" class="btn-primary mt-6">
        Get a Quote
      </a>
    </div>
  </section>
</Base>
