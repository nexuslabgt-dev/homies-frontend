---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';
import { getTranslations } from '@/i18n';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect(`/${locale}/login`);

const userId = session.user.id;

const { data: profile } = await supabase
  .from('profiles')
  .select('role')
  .eq('id', userId)
  .single();

if (profile?.role !== 'admin') {
  return Astro.redirect(`/${locale}/dashboard`);
}

const { count: usersCount } = await supabase
  .from('profiles')
  .select('*', { count: 'exact', head: true });

const { count: caregiversCount } = await supabase
  .from('caregivers')
  .select('*', { count: 'exact', head: true });

const { count: bookingsCount } = await supabase
  .from('bookings')
  .select('*', { count: 'exact', head: true });

const { count: reviewsCount } = await supabase
  .from('reviews')
  .select('*', { count: 'exact', head: true });

const { count: petsCount } = await supabase
  .from('pets')
  .select('*', { count: 'exact', head: true });

const { data: pendingCaregivers } = await supabase
  .from('caregivers')
  .select(`
    id,
    bio,
    experience,
    hourly_rate,
    profiles:user_id (full_name, avatar_url)
  `)
  .eq('is_verified', false)
  .order('created_at', { ascending: false })
  .limit(20);

const { data: recentBookings } = await supabase
  .from('bookings')
  .select(`
    *,
    services:service_id (name),
    pets:pet_id (name),
    client:client_id (full_name),
    caregiver:caregiver_id (profiles:full_name)
  `)
  .order('created_at', { ascending: false })
  .limit(10);
---

<Base title={t.adminDashboard.title} headerVariant="dark">
  <section class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">
          {t.adminDashboard.title}
        </h1>
        <p class="mt-1 text-gray-600 dark:text-gray-400">
          {t.adminDashboard.subtitle}
        </p>
      </div>

      <!-- Stats cards -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5 mb-8">
        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.adminDashboard.totalUsers}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{usersCount ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-accent-100 text-accent-600 dark:bg-accent-900/30 dark:text-accent-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.adminDashboard.totalCaregivers}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{caregiversCount ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-secondary-100 text-secondary-600 dark:bg-secondary-900/30 dark:text-secondary-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.adminDashboard.totalBookings}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{bookingsCount ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.adminDashboard.totalReviews}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{reviewsCount ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.adminDashboard.totalPets}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{petsCount ?? 0}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-3 mb-8">
        <!-- Pending verifications -->
        <div class="lg:col-span-2">
          <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900">
            <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 dark:border-gray-800">
              <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white">
                {t.adminDashboard.pendingVerifications}
              </h2>
            </div>

            {pendingCaregivers && pendingCaregivers.length > 0 ? (
              <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                  <thead class="bg-gray-50 text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                    <tr>
                      <th class="px-6 py-3 font-medium">{t.common.user}</th>
                      <th class="px-6 py-3 font-medium">{t.caregiver.bio}</th>
                      <th class="px-6 py-3 font-medium">{t.caregiver.experience}</th>
                      <th class="px-6 py-3 font-medium">{t.caregiver.hourlyRate}</th>
                      <th class="px-6 py-3 font-medium text-right">{t.common.actions}</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                    {pendingCaregivers.map((caregiver: any) => (
                      <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                        <td class="px-6 py-4">
                          <div class="flex items-center gap-3">
                            {caregiver.profiles?.avatar_url ? (
                              <img src={caregiver.profiles.avatar_url} alt="" class="h-8 w-8 rounded-full object-cover" />
                            ) : (
                              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-200 text-gray-500 dark:bg-gray-700 dark:text-gray-400">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                              </div>
                            )}
                            <span class="font-medium text-gray-900 dark:text-white">
                              {caregiver.profiles?.full_name || t.common.unknown}
                            </span>
                          </div>
                        </td>
                        <td class="px-6 py-4 text-gray-600 dark:text-gray-400 max-w-xs truncate">
                          {caregiver.bio || '-'}
                        </td>
                        <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                          {caregiver.experience || '-'}
                        </td>
                        <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                          {caregiver.hourly_rate ? `$${caregiver.hourly_rate}` : '-'}
                        </td>
                        <td class="px-6 py-4 text-right">
                          <button
                            type="button"
                            data-caregiver-id={caregiver.id}
                            class="verify-btn inline-flex items-center rounded-lg bg-primary-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
                          >
                            {t.adminDashboard.verify}
                          </button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <div class="p-12 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">{t.adminDashboard.noPendingVerifications}</h3>
              </div>
            )}
          </div>
        </div>

        <!-- Quick access -->
        <div>
          <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
            <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-6">
              {t.adminDashboard.quickAccess}
            </h2>
            <div class="space-y-3">
              <a href={`/${locale}/admin`} class="flex items-center gap-3 rounded-lg border border-gray-200 p-4 transition-colors hover:border-primary-300 hover:bg-primary-50 dark:border-gray-700 dark:hover:border-primary-700 dark:hover:bg-primary-900/10">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900 dark:text-white">{t.adminDashboard.adminHome}</p>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent bookings -->
      <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900">
        <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 dark:border-gray-800">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white">
            {t.adminDashboard.recentBookings}
          </h2>
        </div>

        {recentBookings && recentBookings.length > 0 ? (
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead class="bg-gray-50 text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                <tr>
                  <th class="px-6 py-3 font-medium">{t.common.service}</th>
                  <th class="px-6 py-3 font-medium">{t.common.pet}</th>
                  <th class="px-6 py-3 font-medium">{t.common.client}</th>
                  <th class="px-6 py-3 font-medium">{t.common.caregiver}</th>
                  <th class="px-6 py-3 font-medium">{t.dashboardBookings.dates}</th>
                  <th class="px-6 py-3 font-medium">{t.dashboardBookings.price}</th>
                  <th class="px-6 py-3 font-medium">{t.dashboardBookings.status}</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                {recentBookings.map((booking: any) => (
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                    <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">
                      {booking.services?.name || t.common.unknown}
                    </td>
                    <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                      {booking.pets?.name || t.common.unknown}
                    </td>
                    <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                      {booking.client?.full_name || t.common.unknown}
                    </td>
                    <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                      {booking.caregiver?.profiles?.full_name || t.common.unknown}
                    </td>
                    <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                      {booking.start_date ? new Date(booking.start_date).toLocaleDateString(locale) : '-'}
                      {booking.end_date && booking.end_date !== booking.start_date ? ` - ${new Date(booking.end_date).toLocaleDateString(locale)}` : ''}
                    </td>
                    <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                      {booking.total_price ? `$${booking.total_price}` : '-'}
                    </td>
                    <td class="px-6 py-4">
                      {booking.status === 'pending' && (
                        <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">
                          {t.adminDashboard.bookingStatus.pending}
                        </span>
                      )}
                      {booking.status === 'confirmed' && (
                        <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 dark:bg-blue-900/30 dark:text-blue-400">
                          {t.adminDashboard.bookingStatus.confirmed}
                        </span>
                      )}
                      {booking.status === 'in_progress' && (
                        <span class="inline-flex items-center rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-800 dark:bg-purple-900/30 dark:text-purple-400">
                          {t.adminDashboard.bookingStatus.in_progress}
                        </span>
                      )}
                      {booking.status === 'completed' && (
                        <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900/30 dark:text-green-400">
                          {t.adminDashboard.bookingStatus.completed}
                        </span>
                      )}
                      {booking.status === 'cancelled' && (
                        <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800 dark:bg-red-900/30 dark:text-red-400">
                          {t.adminDashboard.bookingStatus.cancelled}
                        </span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="p-12 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">{t.adminDashboard.noRecentBookings}</h3>
          </div>
        )}
      </div>
    </div>
  </section>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.SUPABASE_URL;
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || import.meta.env.SUPABASE_KEY;

    if (supabaseUrl && supabaseKey) {
      const supabase = createClient(supabaseUrl, supabaseKey);

      document.querySelectorAll('.verify-btn').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const caregiverId = target.dataset.caregiverId;
          if (!caregiverId) return;

          target.disabled = true;
          target.textContent = 'Verificando...';

          const { error } = await supabase
            .from('caregivers')
            .update({ is_verified: true })
            .eq('id', caregiverId);

          if (error) {
            console.error('Error verifying caregiver:', error);
            target.disabled = false;
            target.textContent = 'Verificar';
            alert('Error al verificar el cuidador. Inténtalo de nuevo.');
            return;
          }

          window.location.reload();
        });
      });
    }
  </script>
</Base>
