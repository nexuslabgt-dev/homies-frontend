---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';
import { getTranslations } from '@/i18n';

const t = getTranslations(Astro.currentLocale || 'es');

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const userId = session.user.id;

const { data: pets } = await supabase
  .from('pets')
  .select('*')
  .eq('owner_id', userId)
  .order('created_at', { ascending: false });
---

<Base title={t.dashboardPets.title} headerVariant="dark">
  <section class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">
          {t.dashboardPets.title}
        </h1>
        <p class="mt-1 text-gray-600 dark:text-gray-400">
          {t.dashboardPets.subtitle}
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900 overflow-hidden">
            {pets && pets.length > 0 ? (
              <div class="divide-y divide-gray-100 dark:divide-gray-800">
                {pets.map((pet) => (
                  <div class="p-6 flex items-center justify-between">
                    <div class="flex items-center gap-4">
                      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>
                      </div>
                      <div>
                        <p class="font-medium text-gray-900 dark:text-white">{pet.name ?? t.dashboardPets.unnamed}</p>
                        <p class="text-sm text-gray-600 dark:text-gray-400">
                          {pet.type ? pet.type.charAt(0).toUpperCase() + pet.type.slice(1) : t.dashboardPets.unknownType}
                          {pet.breed && ` - ${pet.breed}`}
                        </p>
                        <p class="text-sm text-gray-500 dark:text-gray-500">
                          {pet.size ? pet.size.charAt(0).toUpperCase() + pet.size.slice(1) : t.dashboardPets.unknownSize}
                          {pet.age_months && ` - ${pet.age_months} meses`}
                        </p>
                      </div>
                    </div>
                    <div class="flex items-center gap-2">
                      <button class="rounded-lg px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800">
                        {t.dashboardPets.edit}
                      </button>
                      <button class="rounded-lg px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20">
                        {t.dashboardPets.delete}
                      </button>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="p-12 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
                <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">{t.dashboardPets.noPets}</h3>
                <p class="mt-2 text-gray-600 dark:text-gray-400">{t.dashboardPets.noPetsDesc}</p>
              </div>
            )}
          </div>
        </div>

        <div>
          <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
            <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-6">
              {t.dashboardPets.addNewPet}
            </h2>

            <form id="pet-form" class="space-y-4">
              <div>
                <label for="petName" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  {t.dashboardPets.petName}
                </label>
                <input
                  type="text"
                  id="petName"
                  name="petName"
                  required
                  class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                  placeholder={t.dashboardPets.petNamePlaceholder}
                />
              </div>

              <div>
                <label for="petType" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  {t.dashboardPets.petType}
                </label>
                <select
                  id="petType"
                  name="petType"
                  required
                  class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                >
                  <option value="">{t.dashboardPets.selectType}</option>
                  <option value="dog">{t.dashboardPets.dog}</option>
                  <option value="cat">{t.dashboardPets.cat}</option>
                  <option value="bird">{t.dashboardPets.bird}</option>
                  <option value="other">{t.dashboardPets.other}</option>
                </select>
              </div>

              <div>
                <label for="breed" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  {t.dashboardPets.breed}
                </label>
                <input
                  type="text"
                  id="breed"
                  name="breed"
                  class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                  placeholder={t.dashboardPets.breedPlaceholder}
                />
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="size" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                    {t.dashboardPets.size}
                  </label>
                  <select
                    id="size"
                    name="size"
                    class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                  >
                    <option value="">{t.dashboardPets.select}</option>
                    <option value="small">{t.dashboardPets.small}</option>
                    <option value="medium">{t.dashboardPets.medium}</option>
                    <option value="large">{t.dashboardPets.large}</option>
                  </select>
                </div>

                <div>
                  <label for="ageMonths" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                    {t.dashboardPets.ageMonths}
                  </label>
                  <input
                    type="number"
                    id="ageMonths"
                    name="ageMonths"
                    min="0"
                    class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                    placeholder={t.dashboardPets.agePlaceholder}
                  />
                </div>
              </div>

              <div>
                <label for="notes" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  {t.dashboardPets.notes}
                </label>
                <textarea
                  id="notes"
                  name="notes"
                  rows="3"
                  class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                  placeholder={t.dashboardPets.notesPlaceholder}
                ></textarea>
              </div>

              <div id="form-message" class="hidden text-sm"></div>

              <button type="submit" class="btn-primary w-full">
                {t.dashboardPets.addPet}
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { supabase } from '@/lib/supabase';

  const form = document.getElementById('pet-form') as HTMLFormElement;
  const messageDiv = document.getElementById('form-message') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    messageDiv.classList.add('hidden');

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = '/es/login';
      return;
    }

    const formData = new FormData(form);
    const { error } = await supabase.from('pets').insert({
      owner_id: session.user.id,
      name: formData.get('petName'),
      type: formData.get('petType'),
      breed: formData.get('breed') || null,
      size: formData.get('size') || null,
      age_months: formData.get('ageMonths') ? parseInt(formData.get('ageMonths') as string) : null,
      notes: formData.get('notes') || null,
    });

    if (error) {
      messageDiv.textContent = error.message;
      messageDiv.classList.remove('hidden');
      messageDiv.classList.add('text-red-600', 'dark:text-red-400');
    } else {
      messageDiv.textContent = 'Mascota agregada exitosamente!';
      messageDiv.classList.remove('hidden', 'text-red-600', 'dark:text-red-400');
      messageDiv.classList.add('text-green-600', 'dark:text-green-400');
      form.reset();
      setTimeout(() => window.location.reload(), 1000);
    }
  });
</script>
