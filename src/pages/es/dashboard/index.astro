---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';
import { getTranslations } from '@/i18n';

const t = getTranslations(Astro.currentLocale || 'es');

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const userId = session.user.id;

const { data: profile } = await supabase
  .from('profiles')
  .select('full_name')
  .eq('id', userId)
  .single();

const { count: bookingsCount } = await supabase
  .from('bookings')
  .select('*', { count: 'exact', head: true })
  .eq('client_id', userId);

const { count: petsCount } = await supabase
  .from('pets')
  .select('*', { count: 'exact', head: true })
  .eq('owner_id', userId);

const { data: recentBookings } = await supabase
  .from('bookings')
  .select(`
    *,
    services:service_id(name),
    pets:pet_id(name)
  `)
  .eq('client_id', userId)
  .order('created_at', { ascending: false })
  .limit(5);
---

<Base title={t.dashboard.welcome} headerVariant="dark">
  <section class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">
          {t.dashboard.welcome}, {profile?.full_name?.split(' ')[0] ?? 'there'}
        </h1>
        <p class="mt-1 text-gray-600 dark:text-gray-400">
          {t.dashboard.welcomeDesc}
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 mb-8">
        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.dashboard.bookings}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{bookingsCount ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-accent-100 text-accent-600 dark:bg-accent-900/30 dark:text-accent-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.dashboard.pets}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{petsCount ?? 0}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900">
            <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 dark:border-gray-800">
              <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white">
                {t.dashboard.recentBookings}
              </h2>
              <a href="/es/dashboard/bookings" class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300">
                {t.dashboard.viewAll}
              </a>
            </div>

            {recentBookings && recentBookings.length > 0 ? (
              <div class="divide-y divide-gray-100 dark:divide-gray-800">
                {recentBookings.map((booking) => (
                  <div class="p-6 flex items-center justify-between">
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white">
                        {booking.services?.name ?? t.common.service}
                      </p>
                      <p class="text-sm text-gray-600 dark:text-gray-400">
                        {booking.pets?.name ?? t.common.pet}
                      </p>
                      <p class="text-sm text-gray-500 dark:text-gray-500">
                        {booking.start_date ? new Date(booking.start_date).toLocaleDateString() : t.common.tbd}
                      </p>
                    </div>
                    <div class="text-right">
                      {booking.status === 'pending' && (
                        <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">
                          {t.dashboard.status.pending}
                        </span>
                      )}
                      {booking.status === 'confirmed' && (
                        <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 dark:bg-blue-900/30 dark:text-blue-400">
                          {t.dashboard.status.confirmed}
                        </span>
                      )}
                      {booking.status === 'completed' && (
                        <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900/30 dark:text-green-400">
                          {t.dashboard.status.completed}
                        </span>
                      )}
                      {booking.status === 'cancelled' && (
                        <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800 dark:bg-red-900/30 dark:text-red-400">
                          {t.dashboard.status.cancelled}
                        </span>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="p-12 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">{t.dashboard.noBookings}</h3>
                <p class="mt-2 text-gray-600 dark:text-gray-400">{t.dashboard.noBookingsDesc}</p>
              </div>
            )}
          </div>
        </div>

        <div>
          <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
            <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-6">
              {t.dashboard.quickActions}
            </h2>

            <div class="space-y-3">
              <a href="/es/dashboard/bookings" class="flex items-center gap-3 rounded-lg border border-gray-200 p-4 transition-colors hover:border-primary-300 hover:bg-primary-50 dark:border-gray-700 dark:hover:border-primary-700 dark:hover:bg-primary-900/10">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900 dark:text-white">{t.dashboard.newBooking}</p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">{t.dashboard.newBookingDesc}</p>
                </div>
              </a>

              <a href="/es/dashboard/pets" class="flex items-center gap-3 rounded-lg border border-gray-200 p-4 transition-colors hover:border-accent-300 hover:bg-accent-50 dark:border-gray-700 dark:hover:border-accent-700 dark:hover:bg-accent-900/10">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-accent-100 text-accent-600 dark:bg-accent-900/30 dark:text-accent-400">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900 dark:text-white">{t.dashboard.addPet}</p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">{t.dashboard.addPetDesc}</p>
                </div>
              </a>

              <a href="/es/dashboard/messages" class="flex items-center gap-3 rounded-lg border border-gray-200 p-4 transition-colors hover:border-gray-300 hover:bg-gray-50 dark:border-gray-700 dark:hover:border-gray-600 dark:hover:bg-gray-800">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900 dark:text-white">{t.dashboard.messages}</p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">{t.dashboard.messagesDesc}</p>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
