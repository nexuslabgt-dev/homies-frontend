---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';
import { getTranslations } from '@/i18n';

const t = getTranslations(Astro.currentLocale || 'es');

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const userId = session.user.id;

const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', userId)
  .single();
---

<Base title={t.dashboardProfile.title} headerVariant="dark">
  <section class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">
          {t.dashboardProfile.title}
        </h1>
        <p class="mt-1 text-gray-600 dark:text-gray-400">
          {t.dashboardProfile.subtitle}
        </p>
      </div>

      <div class="max-w-2xl">
        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          {!profile ? (
            <div class="p-6 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
              <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">{t.dashboardProfile.noProfile}</h3>
            </div>
          ) : (
            <div class="space-y-6">
              <!-- Avatar Upload -->
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  {t.dashboardProfile.avatarUpload}
                </label>
                <div class="mt-3 flex items-center gap-4">
                  <div class="relative h-20 w-20 overflow-hidden rounded-full bg-gray-100 dark:bg-gray-800">
                    {profile.avatar_url ? (
                      <img
                        id="avatar-preview"
                        src={profile.avatar_url}
                        alt="Avatar"
                        class="h-full w-full object-cover"
                      />
                    ) : (
                      <div id="avatar-placeholder" class="flex h-full w-full items-center justify-center text-gray-400">
                        <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                      </div>
                      <img id="avatar-preview" class="hidden h-full w-full object-cover" alt="Avatar" />
                    )}
                  </div>
                  <div class="flex-1">
                    <input
                      type="file"
                      id="avatarInput"
                      name="avatarInput"
                      accept="image/jpeg,image/jpg,image/png,image/webp"
                      class="block w-full text-sm text-gray-600 file:mr-4 file:rounded-lg file:border-0 file:bg-primary-600 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-primary-700 dark:text-gray-400 dark:file:bg-primary-700 dark:hover:file:bg-primary-600"
                    />
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                      {t.dashboardProfile.avatarUploadHint}
                    </p>
                  </div>
                </div>
                <div id="avatar-message" class="mt-2 hidden text-sm"></div>
              </div>

              <hr class="border-gray-200 dark:border-gray-700" />

              <form id="profile-form" class="space-y-6" data-success={t.dashboardProfile.success} data-error={t.dashboardProfile.error}>
                <div>
                  <label for="fullName" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                    {t.dashboardProfile.fullName}
                  </label>
                  <input
                    type="text"
                    id="fullName"
                    name="fullName"
                    value={profile.full_name ?? ''}
                    class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                  />
                </div>

                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                    {t.dashboardProfile.phone}
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    value={profile.phone ?? ''}
                    class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                  />
                </div>

                <div>
                  <label for="address" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                    {t.dashboardProfile.address}
                  </label>
                  <input
                    type="text"
                    id="address"
                    name="address"
                    value={profile.address ?? ''}
                    class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                  />
                </div>

                <div>
                  <label for="city" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                    {t.dashboardProfile.city}
                  </label>
                  <input
                    type="text"
                    id="city"
                    name="city"
                    value={profile.city ?? ''}
                    class="mt-1 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                  />
                </div>

                <div id="form-message" class="hidden text-sm"></div>

                <button type="submit" class="btn-primary w-full">
                  {t.dashboardProfile.save}
                </button>
              </form>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { supabase } from '@/lib/supabase';

  const form = document.getElementById('profile-form') as HTMLFormElement | null;
  const messageDiv = document.getElementById('form-message') as HTMLDivElement | null;
  const avatarInput = document.getElementById('avatarInput') as HTMLInputElement | null;
  const avatarMessage = document.getElementById('avatar-message') as HTMLDivElement | null;
  const avatarPreview = document.getElementById('avatar-preview') as HTMLImageElement | null;
  const avatarPlaceholder = document.getElementById('avatar-placeholder') as HTMLDivElement | null;
  if (!form || !messageDiv || !avatarInput || !avatarMessage) throw new Error('Missing form or message elements');

  const INVALID_TYPE_MSG = (form.closest('.space-y-6')?.querySelector('[data-invalid-type]') as HTMLElement)?.dataset.invalidType || 'Tipo de archivo no válido. Usa JPG, PNG o WebP.';
  const TOO_LARGE_MSG = (form.closest('.space-y-6')?.querySelector('[data-too-large]') as HTMLElement)?.dataset.tooLarge || 'El archivo es demasiado grande. Máximo 2MB.';
  const UPLOAD_SUCCESS_MSG = (form.closest('.space-y-6')?.querySelector('[data-upload-success]') as HTMLElement)?.dataset.uploadSuccess || 'Foto actualizada exitosamente';
  const UPLOAD_ERROR_MSG = (form.closest('.space-y-6')?.querySelector('[data-upload-error]') as HTMLElement)?.dataset.uploadError || 'Error al subir la foto';

  // Use text content from the page translation data attributes if present; fallback to hardcoded Spanish
  const tInvalidType = document.querySelector('[data-invalid-type]')?.getAttribute('data-invalid-type') || 'Tipo de archivo no válido. Usa JPG, PNG o WebP.';
  const tTooLarge = document.querySelector('[data-too-large]')?.getAttribute('data-too-large') || 'El archivo es demasiado grande. Máximo 2MB.';
  const tUploadSuccess = document.querySelector('[data-upload-success]')?.getAttribute('data-upload-success') || 'Foto actualizada exitosamente';
  const tUploadError = document.querySelector('[data-upload-error]')?.getAttribute('data-upload-error') || 'Error al subir la foto';

  const ALLOWED_TYPES = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
  const MAX_SIZE = 2 * 1024 * 1024; // 2MB

  async function uploadAvatar(file: File) {
    if (!ALLOWED_TYPES.includes(file.type)) {
      showAvatarMessage(tInvalidType, 'error');
      return;
    }
    if (file.size > MAX_SIZE) {
      showAvatarMessage(tTooLarge, 'error');
      return;
    }

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = '/login';
      return;
    }

    const userId = session.user.id;
    const ext = file.name.split('.').pop() || 'jpg';
    const filePath = `avatars/${userId}/${Date.now()}.${ext}`;

    const { error: uploadError } = await supabase.storage
      .from('uploads')
      .upload(filePath, file, { upsert: true });

    if (uploadError) {
      showAvatarMessage(tUploadError + ': ' + uploadError.message, 'error');
      return;
    }

    const { data: { publicUrl } } = supabase.storage
      .from('uploads')
      .getPublicUrl(filePath);

    const { error: updateError } = await supabase
      .from('profiles')
      .update({ avatar_url: publicUrl, updated_at: new Date().toISOString() })
      .eq('id', userId);

    if (updateError) {
      showAvatarMessage(tUploadError + ': ' + updateError.message, 'error');
      return;
    }

    // Update preview
    if (avatarPreview) {
      avatarPreview.src = publicUrl;
      avatarPreview.classList.remove('hidden');
    }
    if (avatarPlaceholder) {
      avatarPlaceholder.classList.add('hidden');
    }
    showAvatarMessage(tUploadSuccess, 'success');
  }

  function showAvatarMessage(text: string, type: 'success' | 'error') {
    if (!avatarMessage) return;
    avatarMessage.textContent = text;
    avatarMessage.classList.remove('hidden');
    if (type === 'error') {
      avatarMessage.classList.remove('text-green-600', 'dark:text-green-400');
      avatarMessage.classList.add('text-red-600', 'dark:text-red-400');
    } else {
      avatarMessage.classList.remove('text-red-600', 'dark:text-red-400');
      avatarMessage.classList.add('text-green-600', 'dark:text-green-400');
    }
  }

  avatarInput.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    uploadAvatar(file);
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    messageDiv.classList.add('hidden');

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = '/login';
      return;
    }

    const formData = new FormData(form);
    const updates = {
      full_name: (formData.get('fullName') as string) || null,
      phone: (formData.get('phone') as string) || null,
      address: (formData.get('address') as string) || null,
      city: (formData.get('city') as string) || null,
      updated_at: new Date().toISOString(),
    };

    const { error } = await supabase
      .from('profiles')
      .update(updates)
      .eq('id', session.user.id);

    if (error) {
      messageDiv.textContent = form.dataset.error || error.message;
      messageDiv.classList.remove('hidden');
      messageDiv.classList.add('text-red-600', 'dark:text-red-400');
    } else {
      messageDiv.textContent = form.dataset.success || 'Perfil actualizado';
      messageDiv.classList.remove('hidden', 'text-red-600', 'dark:text-red-400');
      messageDiv.classList.add('text-green-600', 'dark:text-green-400');
    }
  });
</script>
