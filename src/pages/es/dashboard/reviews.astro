---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';
import ReviewCard from '@/components/ReviewCard.astro';
import { getTranslations } from '@/i18n';

const t = getTranslations(Astro.currentLocale || 'es');

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const userId = session.user.id;

const { data: reviews } = await supabase
  .from('reviews')
  .select(`
    *,
    bookings:booking_id(service:service_id(name), caregiver:caregiver_id(profiles:profile_id(full_name)))
  `)
  .eq('author_id', userId)
  .order('created_at', { ascending: false });

const { data: completedBookings } = await supabase
  .from('bookings')
  .select(`
    *,
    services:service_id(name),
    caregivers:caregiver_id(profiles:profile_id(full_name))
  `)
  .eq('client_id', userId)
  .eq('status', 'completed')
  .order('created_at', { ascending: false });

const reviewedBookingIds = reviews?.map(r => r.booking_id) || [];
const pendingReviews = completedBookings?.filter(b => !reviewedBookingIds.includes(b.id)) || [];
---

<Base title={t.dashboardReviews.title} headerVariant="dark">
  <section class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">
          {t.dashboardReviews.title}
        </h1>
        <p class="mt-1 text-gray-600 dark:text-gray-400">
          {t.dashboardReviews.subtitle}
        </p>
      </div>

      {pendingReviews.length > 0 && (
        <div class="mb-8 bg-primary-900/20 border border-primary-700 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-white mb-4">{t.reviews.pendingReviews}</h2>
          <p class="text-gray-400 text-sm mb-4">
            {t.reviews.pendingDesc.replace('{count}', String(pendingReviews.length))}
          </p>
          <div class="space-y-3">
            {pendingReviews.slice(0, 3).map((booking) => (
              <div class="flex items-center justify-between bg-gray-800/50 rounded-lg p-4">
                <div>
                  <p class="font-medium text-white">{booking.services?.name || t.reviews.service}</p>
                  <p class="text-sm text-gray-400">con {booking.caregivers?.profiles?.full_name || t.reviews.caregiver}</p>
                </div>
                <a
                  href={`/dashboard/bookings?review=${booking.id}`}
                  class="px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium rounded-lg transition-colors"
                >
                  {t.reviews.leaveReviewBtn}
                </a>
              </div>
            ))}
          </div>
        </div>
      )}

      <div class="mb-6">
        <h2 class="text-xl font-semibold text-white">{t.reviews.writtenReviews}</h2>
      </div>

      {reviews && reviews.length > 0 ? (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {reviews.map((review) => (
            <div class="relative">
              <ReviewCard review={review} />
              <div class="absolute top-4 right-4 flex gap-2">
                <button
                  class="edit-review-btn p-2 bg-gray-700 hover:bg-gray-600 rounded-lg text-gray-400 hover:text-white transition-colors"
                  title={t.reviews.edit}
                  data-review-id={review.id}
                  data-rating={review.rating}
                  data-comment={review.comment || ''}
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                  </svg>
                </button>
                <button
                  class="delete-review-btn p-2 bg-gray-700 hover:bg-red-600 rounded-lg text-gray-400 hover:text-white transition-colors"
                  title={t.reviews.delete}
                  data-review-id={review.id}
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-gray-900/50 rounded-xl">
          <svg class="mx-auto h-16 w-16 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-400">{t.reviews.noWrittenReviews}</h3>
          <p class="mt-2 text-gray-500 text-sm">{t.reviews.noWrittenReviewsDesc}</p>
          <a
            href="/services"
            class="inline-block mt-6 px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-xl transition-colors"
          >
            {t.reviews.seeServices}
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Edit Review Modal -->
  <div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
    <div class="bg-gray-900 border border-gray-700 rounded-2xl w-full max-w-md p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-semibold text-white">{t.reviews.editReview}</h3>
        <button id="close-modal" class="text-gray-400 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <form id="edit-form">
        <div class="mb-4">
          <label class="block text-gray-300 text-sm font-medium mb-2">{t.reviews.rating}</label>
          <div class="flex gap-2" id="edit-star-rating">
            {[1, 2, 3, 4, 5].map((star) => (
              <button
                type="button"
                data-rating={star}
                class="edit-star-btn text-gray-600 hover:text-yellow-400 transition-colors"
              >
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              </button>
            ))}
          </div>
        </div>

        <div class="mb-6">
          <label for="edit-comment" class="block text-gray-300 text-sm font-medium mb-2">{t.reviews.comment}</label>
          <textarea
            id="edit-comment"
            rows="4"
            class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none"
            placeholder={t.reviews.commentPlaceholder}
            required
          ></textarea>
        </div>

        <div class="flex gap-3">
          <button
            type="button"
            id="cancel-edit"
            class="flex-1 px-4 py-2.5 bg-gray-700 hover:bg-gray-600 text-white font-medium rounded-xl transition-colors"
          >
            {t.common.cancel}
          </button>
          <button
            type="submit"
            id="save-edit"
            class="flex-1 px-4 py-2.5 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-xl transition-colors"
          >
            {t.common.save}
          </button>
        </div>
      </form>
    </div>
  </div>
</Base>

<script>
  import { supabase } from '@/lib/supabase';

  const modal = document.getElementById('edit-modal') as HTMLDivElement;
  const closeModalBtn = document.getElementById('close-modal') as HTMLButtonElement;
  const cancelEditBtn = document.getElementById('cancel-edit') as HTMLButtonElement;
  const editForm = document.getElementById('edit-form') as HTMLFormElement;
  const editComment = document.getElementById('edit-comment') as HTMLTextAreaElement;
  const starBtns = document.querySelectorAll('.edit-star-btn') as NodeListOf<HTMLButtonElement>;

  let currentEditId: string | null = null;
  let currentEditRating = 0;

  function updateStars(rating: number) {
    starBtns.forEach((btn, index) => {
      if (index < rating) {
        btn.classList.remove('text-gray-600');
        btn.classList.add('text-yellow-400');
      } else {
        btn.classList.remove('text-yellow-400');
        btn.classList.add('text-gray-600');
      }
    });
  }

  starBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const rating = parseInt(btn.dataset.rating!);
      currentEditRating = rating;
      updateStars(rating);
    });
  });

  function openModal() {
    modal.classList.remove('hidden');
  }

  function closeModal() {
    modal.classList.add('hidden');
    currentEditId = null;
    currentEditRating = 0;
    updateStars(0);
    editComment.value = '';
  }

  closeModalBtn.addEventListener('click', closeModal);
  cancelEditBtn.addEventListener('click', closeModal);

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.querySelectorAll('.edit-review-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLButtonElement;
      currentEditId = el.dataset.reviewId!;
      currentEditRating = parseInt(el.dataset.rating!);
      editComment.value = el.dataset.comment || '';
      updateStars(currentEditRating);
      openModal();
    });
  });

  document.querySelectorAll('.delete-review-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement;
      const reviewId = el.dataset.reviewId!;
      const confirmDelete = window.confirm('¿Estás seguro de que deseas eliminar esta reseña?');
      if (!confirmDelete) return;

      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/es/login';
        return;
      }

      const { error } = await supabase
        .from('reviews')
        .delete()
        .eq('id', reviewId)
        .eq('author_id', session.user.id);

      if (error) {
        alert(error.message);
      } else {
        window.location.reload();
      }
    });
  });

  editForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentEditId) return;

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = '/es/login';
      return;
    }

    if (currentEditRating === 0) {
      alert('Por favor selecciona una calificación.');
      return;
    }

    const saveBtn = document.getElementById('save-edit') as HTMLButtonElement;
    saveBtn.disabled = true;
    saveBtn.textContent = 'Guardando...';

    const { error } = await supabase
      .from('reviews')
      .update({ rating: currentEditRating, comment: editComment.value })
      .eq('id', currentEditId)
      .eq('author_id', session.user.id);

    if (error) {
      alert(error.message);
      saveBtn.disabled = false;
      saveBtn.textContent = 'Guardar';
    } else {
      window.location.reload();
    }
  });
</script>
