---
import Base from '@/layouts/Base.astro';
import { blogPosts, getBlogPost } from '@/data/blog';
import { getTranslations } from '@/i18n';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);

const { slug } = Astro.params;
const { post } = Astro.props;

const formattedDate = new Date(post.date).toLocaleDateString(locale === 'en' ? 'en-US' : 'es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Base title={post.title}>
  <article class="section-padding bg-white dark:bg-gray-950">
    <div class="container mx-auto container-padding">
      <div class="mx-auto max-w-3xl">
        <a href={`/${locale}/blog`} class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 dark:text-primary-400">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {t.blog?.back || 'Volver al blog'}
        </a>

        <div class="mt-8">
          <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
            <span class="rounded-full bg-primary-100 px-3 py-1 text-xs font-medium text-primary-700 dark:bg-primary-900/30 dark:text-primary-400">
              {post.category}
            </span>
            <span>{formattedDate}</span>
            <span>{post.readTime}</span>
          </div>
          
          <h1 class="mt-4 font-serif text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl">
            {post.title}
          </h1>
          
          <div class="mt-8 aspect-video overflow-hidden rounded-2xl">
            <img
              src={post.image}
              alt={post.title}
              class="h-full w-full object-cover"
            />
          </div>
          
          <div class="mt-8 prose prose-lg dark:prose-invert max-w-none" set:html={post.content} />
        </div>
      </div>
    </div>
  </article>
</Base>