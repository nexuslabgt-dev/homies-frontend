---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';
import { getTranslations } from '@/i18n';

const t = getTranslations(Astro.currentLocale || 'es');

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: caregiver } = await supabase
  .from('caregivers')
  .select('id')
  .eq('user_id', session.user.id)
  .single();

if (!caregiver) return Astro.redirect('/caregiver/register');

const { data: completedBookings } = await supabase
  .from('bookings')
  .select('total_price, created_at, service:services(name)')
  .eq('caregiver_id', caregiver.id)
  .eq('status', 'completed')
  .order('created_at', { ascending: false });

const totalEarnings = completedBookings?.reduce((sum, b) => sum + (b.total_price || 0), 0) || 0;

const earningsByService = completedBookings?.reduce((acc, booking) => {
  const serviceName = booking.service?.name || 'Other';
  if (!acc[serviceName]) {
    acc[serviceName] = 0;
  }
  acc[serviceName] += booking.total_price || 0;
  return acc;
}, {} as Record<string, number>) || {};

const monthlyEarnings: Record<string, number> = {};
const currentYear = new Date().getFullYear();
for (let i = 0; i < 12; i++) {
  const monthKey = `${currentYear}-${String(i + 1).padStart(2, '0')}`;
  monthlyEarnings[monthKey] = 0;
}

completedBookings?.forEach((booking) => {
  if (booking.created_at) {
    const date = new Date(booking.created_at);
    if (date.getFullYear() === currentYear) {
      const monthKey = `${currentYear}-${String(date.getMonth() + 1).padStart(2, '0')}`;
      monthlyEarnings[monthKey] = (monthlyEarnings[monthKey] || 0) + (booking.total_price || 0);
    }
  }
});

const maxMonthlyEarning = Math.max(...Object.values(monthlyEarnings), 1);

const { data: pendingBookings } = await supabase
  .from('bookings')
  .select('total_price')
  .eq('caregiver_id', caregiver.id)
  .in('status', ['confirmed', 'in_progress']);

const pendingPayout = pendingBookings?.reduce((sum, b) => sum + (b.total_price || 0), 0) || 0;

const monthLabels = t.caregiverEarnings.months;
---

<Base title={t.caregiverEarnings.title} headerVariant="dark">
  <section class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">
          {t.caregiverEarnings.title}
        </h1>
        <p class="mt-1 text-gray-600 dark:text-gray-400">
          {t.caregiverEarnings.subtitle}
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-8">
        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.caregiverEarnings.totalEarnings}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">
                ${(totalEarnings / 100).toFixed(2)}
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.caregiverEarnings.pendingPayouts}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">
                ${(pendingPayout / 100).toFixed(2)}
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.caregiverEarnings.completedJobs}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">
                {completedBookings?.length ?? 0}
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-3 mb-8">
        <div class="lg:col-span-2">
          <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
            <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-6">
              {t.caregiverEarnings.monthlyEarnings} - {currentYear}
            </h2>

            <div class="h-64 flex items-end justify-between gap-2">
              {Object.entries(monthlyEarnings).map(([monthKey, amount], index) => {
                const heightPercent = (amount / maxMonthlyEarning) * 100;
                const [year, month] = monthKey.split('-');
                return (
                  <div class="flex-1 flex flex-col items-center gap-2">
                    <div class="w-full flex flex-col items-center justify-end h-48">
                      <div
                        class="w-full bg-primary-500 rounded-t dark:bg-primary-600 transition-all hover:bg-primary-600 dark:hover:bg-primary-500"
                        style={`height: ${Math.max(heightPercent, 2)}%; min-height: 4px;`}
                        title={`${monthLabels[index]}: $${(amount / 100).toFixed(2)}`}
                      ></div>
                    </div>
                    <span class="text-xs text-gray-500 dark:text-gray-400">
                      {monthLabels[index]}
                    </span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>

        <div>
          <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
            <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-6">
              {t.caregiverEarnings.earningsByService}
            </h2>

            {Object.keys(earningsByService).length > 0 ? (
              <div class="space-y-4">
                {Object.entries(earningsByService)
                  .sort((a, b) => b[1] - a[1])
                  .map(([service, amount]) => {
                    const percentage = totalEarnings > 0 ? (amount / totalEarnings) * 100 : 0;
                    return (
                      <div>
                        <div class="flex items-center justify-between mb-1">
                          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                            {service}
                          </span>
                          <span class="text-sm text-gray-900 dark:text-white">
                            ${(amount / 100).toFixed(2)}
                          </span>
                        </div>
                        <div class="h-2 bg-gray-200 rounded-full dark:bg-gray-700">
                          <div
                            class="h-2 bg-green-500 rounded-full dark:bg-green-600"
                            style={`width: ${percentage}%`}
                          ></div>
                        </div>
                      </div>
                    );
                  })}
              </div>
            ) : (
              <p class="text-gray-600 dark:text-gray-400 text-center py-8">
                {t.caregiverEarnings.noCompletedBookings}
              </p>
            )}
          </div>
        </div>
      </div>

      <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900 overflow-hidden">
        <div class="border-b border-gray-100 px-6 py-4 dark:border-gray-800">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white">
            {t.caregiverEarnings.paymentHistory}
          </h2>
        </div>

        {completedBookings && completedBookings.length > 0 ? (
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
                    {t.caregiverEarnings.date}
                  </th>
                  <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
                    {t.caregiverEarnings.service}
                  </th>
                  <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
                    {t.caregiverEarnings.amount}
                  </th>
                  <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
                    {t.caregiverEarnings.status}
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                {completedBookings.map((booking) => (
                  <tr>
                    <td class="whitespace-nowrap px-6 py-4">
                      <p class="text-gray-700 dark:text-gray-300">
                        {booking.created_at ? new Date(booking.created_at).toLocaleDateString() : t.common.na}
                      </p>
                    </td>
                    <td class="whitespace-nowrap px-6 py-4">
                      <p class="text-gray-700 dark:text-gray-300">
                        {booking.service?.name ?? t.common.service}
                      </p>
                    </td>
                    <td class="whitespace-nowrap px-6 py-4">
                      <p class="text-green-600 dark:text-green-400 font-medium">
                        +${(booking.total_price / 100).toFixed(2)}
                      </p>
                    </td>
                    <td class="whitespace-nowrap px-6 py-4">
                      <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900/30 dark:text-green-400">
                        {t.caregiverEarnings.paid}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="p-12 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">{t.caregiverEarnings.noPaymentHistory}</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">{t.caregiverEarnings.noPaymentHistoryDesc}</p>
          </div>
        )}
      </div>
    </div>
  </section>
</Base>
