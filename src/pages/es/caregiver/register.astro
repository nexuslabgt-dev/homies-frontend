---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: existingCaregiver } = await supabase
  .from('caregivers')
  .select('id')
  .eq('user_id', session.user.id)
  .single();

if (existingCaregiver) return Astro.redirect('/caregiver/dashboard');

const { data: services } = await supabase
  .from('services')
  .select('id, name')
  .order('name');
---

<Base title="Caregiver Registration" headerVariant="dark">
  <section class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12">
    <div class="container mx-auto px-4 lg:px-8 max-w-2xl">
      <div class="mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">
          Become a Caregiver
        </h1>
        <p class="mt-1 text-gray-600 dark:text-gray-400">
          Join our network of trusted pet caregivers
        </p>
      </div>

      <form action="/api/caregiver/register" method="POST" class="space-y-6">
        <input type="hidden" name="user_id" value={session.user.id} />

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-6">
            About You
          </h2>

          <div class="space-y-4">
            <div>
              <label for="bio" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                Bio
              </label>
              <textarea
                id="bio"
                name="bio"
                rows="4"
                required
                placeholder="Tell clients about yourself and your experience with pets..."
                class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
              ></textarea>
            </div>

            <div>
              <label for="experience" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                Experience (years)
              </label>
              <input
                type="number"
                id="experience"
                name="experience"
                min="0"
                max="50"
                required
                placeholder="5"
                class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
              />
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-6">
            Services Offered
          </h2>

          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            Select the services you would like to offer
          </p>

          <div class="grid gap-3 sm:grid-cols-2">
            {services?.map((service) => (
              <label class="flex items-center gap-3 rounded-lg border border-gray-200 p-4 cursor-pointer hover:border-primary-300 dark:border-gray-700 dark:hover:border-primary-700 transition-colors">
                <input
                  type="checkbox"
                  name="services"
                  value={service.id}
                  class="h-5 w-5 rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                />
                <span class="text-gray-900 dark:text-white">{service.name}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-6">
            Pricing
          </h2>

          <div>
            <label for="hourly_rate" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Hourly Rate ($)
            </label>
            <input
              type="number"
              id="hourly_rate"
              name="hourly_rate"
              min="1"
              step="0.01"
              required
              placeholder="25.00"
              class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-primary-600 px-6 py-3 text-base font-medium text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors"
        >
          Complete Registration
        </button>
      </form>
    </div>
  </section>
</Base>
