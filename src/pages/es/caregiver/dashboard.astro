---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';
import { getTranslations } from '@/i18n';

const t = getTranslations(Astro.currentLocale || 'es');

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/es/login');

const { data: caregiver } = await supabase
  .from('caregivers')
  .select('*, profiles(full_name)')
  .eq('user_id', session.user.id)
  .single();

if (!caregiver) return Astro.redirect('/es/caregiver/register');

const today = new Date();
today.setHours(0, 0, 0, 0);
const tomorrow = new Date(today);
tomorrow.setDate(tomorrow.getDate() + 1);

const { data: todayBookings } = await supabase
  .from('bookings')
  .select('*, client:profiles(full_name), pet:pets(name, species), service:services(name)')
  .eq('caregiver_id', caregiver.id)
  .gte('start_date', today.toISOString())
  .lt('start_date', tomorrow.toISOString());

const { data: upcomingBookings } = await supabase
  .from('bookings')
  .select('*, client:profiles(full_name), pet:pets(name, species), service:services(name)')
  .eq('caregiver_id', caregiver.id)
  .gte('start_date', tomorrow.toISOString())
  .in('status', ['confirmed', 'in_progress'])
  .order('start_date', { ascending: true })
  .limit(5);

const { data: completedBookings } = await supabase
  .from('bookings')
  .select('total_price, status')
  .eq('caregiver_id', caregiver.id)
  .eq('status', 'completed');

const totalEarnings = completedBookings?.reduce((sum, b) => sum + (b.total_price || 0), 0) || 0;

const { count: pendingRequests } = await supabase
  .from('bookings')
  .select('*', { count: 'exact', head: true })
  .eq('caregiver_id', caregiver.id)
  .eq('status', 'pending');

const { count: activeBookings } = await supabase
  .from('bookings')
  .select('*', { count: 'exact', head: true })
  .eq('caregiver_id', caregiver.id)
  .in('status', ['confirmed', 'in_progress']);

const { data: reviews } = await supabase
  .from('reviews')
  .select('*, booking:bookings(service_id)')
  .eq('caregiver_id', caregiver.id)
  .order('created_at', { ascending: false })
  .limit(5);

const { data: reviewStats } = await supabase
  .from('reviews')
  .select('rating')
  .eq('caregiver_id', caregiver.id);

const avgRating = reviewStats?.length
  ? (reviewStats.reduce((sum, r) => sum + r.rating, 0) / reviewStats.length).toFixed(1)
  : '0.0';
---

<Base title={t.caregiverDashboard.welcome} headerVariant="dark">
  <section class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">
          {t.caregiverDashboard.welcome}, {caregiver.profiles?.full_name?.split(' ')[0] ?? 'Caregiver'}
        </h1>
        <p class="mt-1 text-gray-600 dark:text-gray-400">
          {t.caregiverDashboard.welcomeDesc}
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 mb-8">
        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.caregiverDashboard.pendingRequests}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{pendingRequests ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.caregiverDashboard.activeBookings}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{activeBookings ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.caregiverDashboard.reviews}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{reviewStats?.length ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">{t.caregiverDashboard.avgRating}</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{avgRating} / 5</p>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-4 mb-8">
        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-2">
            {t.caregiverDashboard.totalEarnings}
          </h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">{t.caregiverDashboard.totalEarningsDesc}</p>
          <p class="text-3xl font-bold text-green-600 dark:text-green-400">
            ${(totalEarnings / 100).toFixed(2)}
          </p>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-2">
            {t.caregiverDashboard.todaysBookings}
          </h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">{today.toLocaleDateString()}</p>
          <p class="text-3xl font-bold text-gray-900 dark:text-white">
            {todayBookings?.length ?? 0}
          </p>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-2">
            {t.caregiverDashboard.hourlyRate}
          </h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">{t.caregiverDashboard.hourlyRateDesc}</p>
          <p class="text-3xl font-bold text-gray-900 dark:text-white">
            ${caregiver.hourly_rate ? (caregiver.hourly_rate / 100).toFixed(2) : '0.00'}/hr
          </p>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-2">
            {t.caregiverDashboard.availability}
          </h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">{t.caregiverDashboard.availabilityDesc}</p>
          <div id="availability-data" data-availability={JSON.stringify(caregiver.availability || [])} class="hidden"></div>
          <form id="availability-form" data-caregiver-id={caregiver.id} data-saved-message={t.caregiverDashboard.availabilitySaved} class="space-y-3">
            {[
              { key: 'monday', label: t.caregiverDashboard.monday },
              { key: 'tuesday', label: t.caregiverDashboard.tuesday },
              { key: 'wednesday', label: t.caregiverDashboard.wednesday },
              { key: 'thursday', label: t.caregiverDashboard.thursday },
              { key: 'friday', label: t.caregiverDashboard.friday },
              { key: 'saturday', label: t.caregiverDashboard.saturday },
              { key: 'sunday', label: t.caregiverDashboard.sunday },
            ].map((day) => (
              <div class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-4">
                <label class="flex items-center gap-2 min-w-[120px] cursor-pointer">
                  <input
                    type="checkbox"
                    value={day.key}
                    class="day-checkbox h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-600 dark:border-gray-600 dark:bg-gray-800"
                    data-day={day.key}
                  />
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">{day.label}</span>
                </label>
                <div class="day-times hidden flex-1 flex flex-col sm:flex-row gap-2">
                  <div class="flex-1">
                    <label class="block text-xs text-gray-500 dark:text-gray-400 mb-1">{t.caregiverDashboard.startTime}</label>
                    <input
                      type="time"
                      class="start-time w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-900 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                      data-day={day.key}
                    />
                  </div>
                  <div class="flex-1">
                    <label class="block text-xs text-gray-500 dark:text-gray-400 mb-1">{t.caregiverDashboard.endTime}</label>
                    <input
                      type="time"
                      class="end-time w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-900 focus:border-primary-600 focus:outline-none focus:ring-1 focus:ring-primary-600 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                      data-day={day.key}
                    />
                  </div>
                </div>
              </div>
            ))}
            <div id="availability-message" class="hidden text-sm pt-2"></div>
            <button type="submit" class="btn-primary w-full mt-4">
              {t.caregiverDashboard.saveAvailability}
            </button>
          </form>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900 mb-8">
            <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 dark:border-gray-800">
              <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white">
                {t.caregiverDashboard.upcomingBookings}
              </h2>
              <a href="/es/caregiver/bookings" class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300">
                {t.caregiverDashboard.viewAll}
              </a>
            </div>

            {upcomingBookings && upcomingBookings.length > 0 ? (
              <div class="divide-y divide-gray-100 dark:divide-gray-800">
                {upcomingBookings.map((booking) => (
                  <div class="p-6 flex items-center justify-between">
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white">
                        {booking.service?.name ?? t.caregiverDashboard.service}
                      </p>
                      <p class="text-sm text-gray-600 dark:text-gray-400">
                        {booking.pet?.name ?? t.caregiverDashboard.pet} - {booking.pet?.species ?? ''}
                      </p>
                      <p class="text-sm text-gray-500 dark:text-gray-500">
                        {t.caregiverDashboard.client}: {booking.client?.full_name ?? t.common.tbd}
                      </p>
                      <p class="text-sm text-gray-500 dark:text-gray-500">
                        {booking.start_date ? new Date(booking.start_date).toLocaleDateString() : t.common.tbd}
                      </p>
                    </div>
                    <div class="text-right">
                      {booking.status === 'confirmed' && (
                        <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 dark:bg-blue-900/30 dark:text-blue-400">
                          {t.caregiverDashboard.status.confirmed}
                        </span>
                      )}
                      {booking.status === 'in_progress' && (
                        <span class="inline-flex items-center rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-800 dark:bg-purple-900/30 dark:text-purple-400">
                          {t.caregiverDashboard.status.inProgress}
                        </span>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="p-12 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">{t.caregiverDashboard.noUpcoming}</h3>
                <p class="mt-2 text-gray-600 dark:text-gray-400">{t.caregiverDashboard.noUpcomingDesc}</p>
              </div>
            )}
          </div>

          {todayBookings && todayBookings.length > 0 && (
            <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900">
              <div class="border-b border-gray-100 px-6 py-4 dark:border-gray-800">
                <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white">
                  {t.caregiverDashboard.todaysSchedule}
                </h2>
              </div>
              <div class="divide-y divide-gray-100 dark:divide-gray-800">
                {todayBookings.map((booking) => (
                  <div class="p-6 flex items-center justify-between">
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white">
                        {booking.service?.name ?? t.caregiverDashboard.service}
                      </p>
                      <p class="text-sm text-gray-600 dark:text-gray-400">
                        {booking.pet?.name ?? t.caregiverDashboard.pet} para {booking.client?.full_name ?? t.caregiverDashboard.client}
                      </p>
                    </div>
                    <div>
                      <a
                        href={`/es/dashboard/messages?client=${booking.client_id}`}
                        class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
                      >
                        {t.caregiverDashboard.contactClient}
                      </a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <div>
          <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900">
            <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 dark:border-gray-800">
              <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white">
                {t.caregiverDashboard.recentReviews}
              </h2>
            </div>

            {reviews && reviews.length > 0 ? (
              <div class="divide-y divide-gray-100 dark:divide-gray-800">
                {reviews.map((review) => (
                  <div class="p-6">
                    <div class="flex items-center gap-1 mb-2">
                      {[...Array(5)].map((_, i) => (
                        <svg
                          class={`h-4 w-4 ${i < review.rating ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600'}`}
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      {review.comment || '¡Gran servicio!'}
                    </p>
                  </div>
                ))}
              </div>
            ) : (
              <div class="p-12 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
                <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">{t.caregiverDashboard.noReviews}</h3>
                <p class="mt-2 text-gray-600 dark:text-gray-400">{t.caregiverDashboard.noReviewsDesc}</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { supabase } from '@/lib/supabase';

    const form = document.getElementById('availability-form') as HTMLFormElement;
    const messageDiv = document.getElementById('availability-message') as HTMLDivElement;
    const availabilityDataEl = document.getElementById('availability-data') as HTMLDivElement;

    const caregiverId = form.dataset.caregiverId!;
    const savedMessage = form.dataset.savedMessage!;
    const availability = JSON.parse(availabilityDataEl.dataset.availability || '[]') as Array<{ day: string; start: string; end: string }>;

    // Initialize existing availability
    availability.forEach((slot) => {
      const checkbox = form.querySelector(`input[type="checkbox"][data-day="${slot.day}"]`) as HTMLInputElement;
      if (checkbox) {
        checkbox.checked = true;
        const row = checkbox.closest('.flex')?.querySelector('.day-times') as HTMLDivElement;
        if (row) {
          row.classList.remove('hidden');
          const startInput = row.querySelector('.start-time') as HTMLInputElement;
          const endInput = row.querySelector('.end-time') as HTMLInputElement;
          if (startInput) startInput.value = slot.start;
          if (endInput) endInput.value = slot.end;
        }
      }
    });

    // Toggle time inputs on checkbox change
    form.querySelectorAll('.day-checkbox').forEach((checkbox) => {
      checkbox.addEventListener('change', () => {
        const cb = checkbox as HTMLInputElement;
        const row = cb.closest('.flex')?.querySelector('.day-times') as HTMLDivElement;
        if (row) {
          if (cb.checked) {
            row.classList.remove('hidden');
            const startInput = row.querySelector('.start-time') as HTMLInputElement;
            const endInput = row.querySelector('.end-time') as HTMLInputElement;
            if (!startInput.value) startInput.value = '08:00';
            if (!endInput.value) endInput.value = '18:00';
          } else {
            row.classList.add('hidden');
            const startInput = row.querySelector('.start-time') as HTMLInputElement;
            const endInput = row.querySelector('.end-time') as HTMLInputElement;
            startInput.value = '';
            endInput.value = '';
          }
        }
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      messageDiv.classList.add('hidden');

      const checkboxes = form.querySelectorAll('.day-checkbox:checked');
      const availabilityArray: { day: string; start: string; end: string }[] = [];

      checkboxes.forEach((checkbox) => {
        const cb = checkbox as HTMLInputElement;
        const row = cb.closest('.flex')?.querySelector('.day-times') as HTMLDivElement;
        const start = (row.querySelector('.start-time') as HTMLInputElement).value;
        const end = (row.querySelector('.end-time') as HTMLInputElement).value;

        if (start && end) {
          availabilityArray.push({ day: cb.value, start, end });
        }
      });

      const { error } = await supabase
        .from('caregivers')
        .update({ availability: availabilityArray })
        .eq('id', caregiverId);

      if (error) {
        messageDiv.textContent = error.message;
        messageDiv.classList.remove('hidden');
        messageDiv.classList.add('text-red-600', 'dark:text-red-400');
        return;
      }

      messageDiv.textContent = savedMessage;
      messageDiv.classList.remove('hidden');
      messageDiv.classList.add('text-green-600', 'dark:text-green-400');
    });
  </script>
</Base>
