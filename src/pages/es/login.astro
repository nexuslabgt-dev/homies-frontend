---
import Base from '@/layouts/Base.astro';
import LoginForm from '@/components/LoginForm.astro';
import { getTranslations } from '@/i18n';

const t = getTranslations(Astro.currentLocale || 'es');
---

<Base title={t.login.title} headerVariant="dark">
  <section class="relative min-h-screen bg-primary-600 py-20 lg:py-28">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 -right-40 h-80 w-80 rounded-full bg-primary-500 opacity-20 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 h-80 w-80 rounded-full bg-accent-500 opacity-20 blur-3xl"></div>
    </div>

    <div class="relative container mx-auto px-4 lg:px-8">
      <div class="flex flex-col items-center justify-center">
        <div class="mb-8 text-center" data-animate>
          <h1 class="font-serif text-4xl font-bold text-white sm:text-5xl">
            {t.login.title}
          </h1>
          <p class="mx-auto mt-4 max-w-md text-lg text-primary-100">
            {t.login.subtitle}
          </p>
        </div>

        <div
          class="w-full max-w-md rounded-2xl bg-white p-8 shadow-xl dark:bg-gray-900"
          data-animate
          data-delay="200"
        >
          <LoginForm />

          <p class="mt-6 text-center text-sm text-gray-600 dark:text-gray-400">
            {t.login.register}
            <a
              href="/es/register"
              class="font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
            >
              {t.login.registerLink}
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
