---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: caregiver } = await supabase
  .from('caregivers')
  .select('*, profiles:profile_id(full_name)')
  .eq('user_id', session.user.id)
  .single();

if (!caregiver) return Astro.redirect('/caregiver/register');

const today = new Date();
today.setHours(0, 0, 0, 0);
const tomorrow = new Date(today);
tomorrow.setDate(tomorrow.getDate() + 1);

const { data: todayBookings } = await supabase
  .from('bookings')
  .select('*, client:profiles(full_name), pet:pets(name, species), service:services(name)')
  .eq('caregiver_id', caregiver.id)
  .gte('start_date', today.toISOString())
  .lt('start_date', tomorrow.toISOString());

const { data: upcomingBookings } = await supabase
  .from('bookings')
  .select('*, client:profiles(full_name), pet:pets(name, species), service:services(name)')
  .eq('caregiver_id', caregiver.id)
  .gte('start_date', tomorrow.toISOString())
  .in('status', ['confirmed', 'in_progress'])
  .order('start_date', { ascending: true })
  .limit(5);

const { data: completedBookings } = await supabase
  .from('bookings')
  .select('total_price, status')
  .eq('caregiver_id', caregiver.id)
  .eq('status', 'completed');

const totalEarnings = completedBookings?.reduce((sum, b) => sum + (b.total_price || 0), 0) || 0;

const { count: pendingRequests } = await supabase
  .from('bookings')
  .select('*', { count: 'exact', head: true })
  .eq('caregiver_id', caregiver.id)
  .eq('status', 'pending');

const { count: activeBookings } = await supabase
  .from('bookings')
  .select('*', { count: 'exact', head: true })
  .eq('caregiver_id', caregiver.id)
  .in('status', ['confirmed', 'in_progress']);

const { data: reviews } = await supabase
  .from('reviews')
  .select('*, booking:bookings(service_id)')
  .eq('caregiver_id', caregiver.id)
  .order('created_at', { ascending: false })
  .limit(5);

const { data: reviewStats } = await supabase
  .from('reviews')
  .select('rating')
  .eq('caregiver_id', caregiver.id);

const avgRating = reviewStats?.length
  ? (reviewStats.reduce((sum, r) => sum + r.rating, 0) / reviewStats.length).toFixed(1)
  : '0.0';
---

<Base title="Caregiver Dashboard" headerVariant="dark">
  <section class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">
          Welcome back, {caregiver.profiles?.full_name?.split(' ')[0] ?? 'Caregiver'}
        </h1>
        <p class="mt-1 text-gray-600 dark:text-gray-400">
          Here's your caregiver dashboard overview.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 mb-8">
        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">Pending Requests</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{pendingRequests ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">Active Bookings</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{activeBookings ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">Reviews</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{reviewStats?.length ?? 0}</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">Avg Rating</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">{avgRating} / 5</p>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-3 mb-8">
        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-2">
            Total Earnings
          </h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">From completed bookings</p>
          <p class="text-3xl font-bold text-green-600 dark:text-green-400">
            ${(totalEarnings / 100).toFixed(2)}
          </p>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-2">
            Today's Bookings
          </h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">{today.toLocaleDateString()}</p>
          <p class="text-3xl font-bold text-gray-900 dark:text-white">
            {todayBookings?.length ?? 0}
          </p>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-gray-900">
          <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white mb-2">
            Hourly Rate
          </h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Your current rate</p>
          <p class="text-3xl font-bold text-gray-900 dark:text-white">
            ${caregiver.hourly_rate ? (caregiver.hourly_rate / 100).toFixed(2) : '0.00'}/hr
          </p>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900 mb-8">
            <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 dark:border-gray-800">
              <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white">
                Upcoming Bookings
              </h2>
              <a href="/en/caregiver/bookings" class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300">
                View all
              </a>
            </div>

            {upcomingBookings && upcomingBookings.length > 0 ? (
              <div class="divide-y divide-gray-100 dark:divide-gray-800">
                {upcomingBookings.map((booking) => (
                  <div class="p-6 flex items-center justify-between">
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white">
                        {booking.service?.name ?? 'Service'}
                      </p>
                      <p class="text-sm text-gray-600 dark:text-gray-400">
                        {booking.pet?.name ?? 'Pet'} - {booking.pet?.species ?? ''}
                      </p>
                      <p class="text-sm text-gray-500 dark:text-gray-500">
                        Client: {booking.client?.full_name ?? 'TBD'}
                      </p>
                      <p class="text-sm text-gray-500 dark:text-gray-500">
                        {booking.start_date ? new Date(booking.start_date).toLocaleDateString() : 'TBD'}
                      </p>
                    </div>
                    <div class="text-right">
                      {booking.status === 'confirmed' && (
                        <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 dark:bg-blue-900/30 dark:text-blue-400">
                          Confirmed
                        </span>
                      )}
                      {booking.status === 'in_progress' && (
                        <span class="inline-flex items-center rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-800 dark:bg-purple-900/30 dark:text-purple-400">
                          In Progress
                        </span>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="p-12 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No upcoming bookings</h3>
                <p class="mt-2 text-gray-600 dark:text-gray-400">New booking requests will appear here.</p>
              </div>
            )}
          </div>

          {todayBookings && todayBookings.length > 0 && (
            <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900">
              <div class="border-b border-gray-100 px-6 py-4 dark:border-gray-800">
                <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white">
                  Today's Schedule
                </h2>
              </div>
              <div class="divide-y divide-gray-100 dark:divide-gray-800">
                {todayBookings.map((booking) => (
                  <div class="p-6 flex items-center justify-between">
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white">
                        {booking.service?.name ?? 'Service'}
                      </p>
                      <p class="text-sm text-gray-600 dark:text-gray-400">
                        {booking.pet?.name ?? 'Pet'} for {booking.client?.full_name ?? 'Client'}
                      </p>
                    </div>
                    <div>
                      <a
                        href={`/en/dashboard/messages?client=${booking.client_id}`}
                        class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
                      >
                        Contact Client
                      </a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <div>
          <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900">
            <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 dark:border-gray-800">
              <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-white">
                Recent Reviews
              </h2>
            </div>

            {reviews && reviews.length > 0 ? (
              <div class="divide-y divide-gray-100 dark:divide-gray-800">
                {reviews.map((review) => (
                  <div class="p-6">
                    <div class="flex items-center gap-1 mb-2">
                      {[...Array(5)].map((_, i) => (
                        <svg
                          class={`h-4 w-4 ${i < review.rating ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600'}`}
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      {review.comment || 'Great service!'}
                    </p>
                  </div>
                ))}
              </div>
            ) : (
              <div class="p-12 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
                <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No reviews yet</h3>
                <p class="mt-2 text-gray-600 dark:text-gray-400">Complete bookings to receive reviews.</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
