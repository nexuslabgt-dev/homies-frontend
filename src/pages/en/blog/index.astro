---
import Base from '@/layouts/Base.astro';
import BlogCard from '@/components/BlogCard.astro';
import { blogPosts } from '@/data/blog';
import { getTranslations } from '@/i18n';

const locale = Astro.currentLocale || 'es';
const t = getTranslations(locale);
---

<Base title={t.blog?.pageTitle || 'Tips Blog'}>
  <section class="relative bg-primary-600 py-32 pt-40 lg:py-28 lg:pt-40">
    <div class="container mx-auto px-4 text-center lg:px-8">
      <h1 class="font-serif text-4xl font-bold text-white sm:text-5xl">
        {t.blog?.heading || 'Tips Blog'}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
        {t.blog?.subtitle || 'Advice and guides for caring for your pets'}
      </p>
    </div>
  </section>

  <section class="section-padding bg-gray-50 dark:bg-gray-900">
    <div class="container mx-auto container-padding">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {blogPosts.map((post, index) => (
          <div data-animate data-delay={index * 100}>
            <BlogCard post={post} locale={locale} />
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>