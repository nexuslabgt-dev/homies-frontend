---
import Base from '@/layouts/Base.astro';
import ServiceMap from '@/components/sections/ServiceMap.astro';
import { getTranslations } from '@/i18n';

const locale = Astro.currentLocale || 'en';
const t = getTranslations(locale);
---

<Base title={t.coverage.title} headerVariant="dark">
  <section class="relative bg-primary-600 pb-20 pt-32 lg:pb-28 lg:pt-40">
    <div class="container mx-auto px-4 text-center lg:px-8">
      <h1 class="font-serif text-4xl font-bold text-white sm:text-5xl">
        {t.coverage.title}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
        {t.coverage.subtitle}
      </p>
    </div>
  </section>

  <ServiceMap />

  <section class="section-padding bg-primary-50 dark:bg-gray-900">
    <div class="container mx-auto container-padding">
      <div class="mx-auto max-w-2xl text-center" data-animate>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          {t.coverage.note}
        </p>
        <a
          href="https://api.whatsapp.com/send?phone=50234768028"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center gap-2 btn-primary"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.405,3.488C18.161,1.238 15.171,-0 11.995,-0C5.437,-0 0.102,5.336 0.102,11.893C0.102,13.988 0.648,16.034 1.687,17.839L-0,24L6.305,22.345C8.041,23.293 9.996,23.791 11.989,23.791L11.995,23.791C18.546,23.791 24,18.455 24,11.898C24,8.721 22.65,5.738 20.405,3.488L20.405,3.488ZM11.995,21.788C10.216,21.788 8.475,21.311 6.959,20.411L6.6,20.196L2.861,21.177L3.857,17.529L3.621,17.154C2.63,15.579 2.111,13.763 2.111,11.893C2.111,6.445 6.546,2.009 12,2.009C14.641,2.009 17.121,3.038 18.986,4.907C20.85,6.777 21.996,9.257 21.991,11.898C21.991,17.352 17.443,21.788 11.995,21.788Z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</Base>